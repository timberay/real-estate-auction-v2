RAILS_ENV=development
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# LLM tunables (all optional — defaults baked in)
# LLM_TIMEOUT_SECONDS=300
# LLM_OPEN_TIMEOUT_SECONDS=10
# LLM_MODEL=                     # global override; per-provider takes precedence
# ANTHROPIC_BASE_URL=            ANTHROPIC_MODEL=     ANTHROPIC_MAX_TOKENS=8192   ANTHROPIC_API_VERSION=2023-06-01
# OPENAI_BASE_URL=               OPENAI_MODEL=        OPENAI_MAX_TOKENS=4096
# GEMINI_BASE_URL=               GEMINI_MODEL=
# OPENROUTER_BASE_URL=           OPENROUTER_MODEL=    OPENROUTER_MAX_TOKENS=4096
# OLLAMA_BASE_URL=               OLLAMA_MODEL=

# Mailer (production)
# MAILER_FROM_ADDRESS=no-reply@yourdomain.com
# MAILER_HOST=yourdomain.com

# Kamal deploy targets (override per environment)
# KAMAL_DEPLOY_HOST=10.0.0.1
# KAMAL_REGISTRY_SERVER=registry.example.com

# Reserve fund defaults are managed in db/seeds/reserve_fund_defaults.json
# To update default values: edit the JSON file and run `bin/rails db:seed`
# Acquisition tax rates by property type:
#   apartment (< 85㎡): 1.1%
#   apartment (>= 136㎡): 3.5%
#   officetel: 4.4%
#   villa: 1.1%
