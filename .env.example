RAILS_ENV=development
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Mailer (production)
# MAILER_FROM_ADDRESS=no-reply@yourdomain.com
# MAILER_HOST=yourdomain.com

# Kamal deploy targets (override per environment)
# KAMAL_DEPLOY_HOST=10.0.0.1
# KAMAL_REGISTRY_SERVER=registry.example.com

# Reserve fund defaults are managed in db/seeds/reserve_fund_defaults.json
# To update default values: edit the JSON file and run `bin/rails db:seed`
# Acquisition tax rates by property type:
#   apartment (< 85㎡): 1.1%
#   apartment (>= 136㎡): 3.5%
#   officetel: 4.4%
#   villa: 1.1%
