RAILS_ENV=development
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# LLM tunables (all optional — defaults baked in)
# LLM_TIMEOUT_SECONDS=300
# LLM_OPEN_TIMEOUT_SECONDS=10
# LLM_MODEL=                     # global override; per-provider takes precedence
# ANTHROPIC_BASE_URL=            ANTHROPIC_MODEL=     ANTHROPIC_MAX_TOKENS=8192   ANTHROPIC_API_VERSION=2023-06-01
# OPENAI_BASE_URL=               OPENAI_MODEL=        OPENAI_MAX_TOKENS=4096
# GEMINI_BASE_URL=               GEMINI_MODEL=
# OPENROUTER_BASE_URL=           OPENROUTER_MODEL=    OPENROUTER_MAX_TOKENS=4096
# OLLAMA_BASE_URL=               OLLAMA_MODEL=

# Mailer (production)
# MAILER_FROM_ADDRESS=no-reply@yourdomain.com
# MAILER_HOST=yourdomain.com

# Production host — must match deploy.yml proxy.host. Required at boot (ENV.fetch raises if missing).
# APP_HOST=yourdomain.com

# Kamal deploy targets (override per environment)
# KAMAL_DEPLOY_HOST=10.0.0.1
# KAMAL_REGISTRY_SERVER=registry.example.com

# Operational tunables (all optional — sensible defaults baked in)
# COURT_AUCTION_HOST=https://www.courtauction.go.kr
# COURT_AUCTION_MIN_REQUEST_INTERVAL=0.5
# COURT_AUCTION_MAX_REQUESTS_PER_MINUTE=60
# COURT_AUCTION_CRITERIA_SEARCH_TIMEOUT=30
# COURT_AUCTION_CRITERIA_SEARCH_OPEN_TIMEOUT=10
# COURT_AUCTION_CASE_SEARCH_OPEN_TIMEOUT=5
# COURT_AUCTION_CASE_SEARCH_READ_TIMEOUT=10
# BROWSER_TIMEOUT=90
# BROWSER_PAGE_LOAD_WAIT_SECONDS=3
# AUTH_RATE_LIMIT_ATTEMPTS=10
# AUTH_RATE_LIMIT_PERIOD_SECONDS=60
# AUTH_HOUR_RATE_LIMIT_ATTEMPTS=100        # W0-3.3: progressive backoff (hour-window tier)
# AUTH_HOUR_RATE_LIMIT_PERIOD_SECONDS=3600
# ANALYSES_PROMPT_RATE_LIMIT_ATTEMPTS=60
# ANALYSES_PROMPT_RATE_LIMIT_PERIOD_SECONDS=60
# ANALYSES_PROMPT_HOUR_RATE_LIMIT_ATTEMPTS=600
# ANALYSES_PROMPT_HOUR_RATE_LIMIT_PERIOD_SECONDS=3600
# BLOCKED_IPS=                             # W0-3.3: comma-separated static denylist (e.g. "1.2.3.4,5.6.7.8")
# MAX_PDF_UPLOAD_MEGABYTES=5
# PDF_ANALYSIS_RETRY_WAIT_SECONDS=5
# PDF_ANALYSIS_RETRY_ATTEMPTS=2
# GUEST_STALE_AFTER_DAYS=30
# EVICTION_SIMULATION_STALE_AFTER_HOURS=24
# LAST_SEEN_TTL_SECONDS=60

# Reserve fund defaults are managed in db/seeds/reserve_fund_defaults.json
# To update default values: edit the JSON file and run `bin/rails db:seed`
# Acquisition tax rates by property type:
#   apartment (< 85㎡): 1.1%
#   apartment (>= 136㎡): 3.5%
#   officetel: 4.4%
#   villa: 1.1%
