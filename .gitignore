# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Bundler config.
/.bundle

# Environment files (keep .env.example as reference).
/.env*
!/.env.example

# Logs and temp files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Storage (uploaded files and SQLite databases in development).
/storage/*
!/storage/.keep

# Asset builds (Propshaft + TailwindCSS).
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Rails credentials key files (master + per-environment).
/config/*.key
/config/credentials/*.key

# Bootsnap cache.
/tmp/cache/bootsnap/

# Test coverage output (SimpleCov, etc.).
/coverage/

# Ruby REPL / debugger history (may contain secrets typed into a console).
.irb_history
.pry_history
.byebug_history
.rdbg_history

# Kamal deployment secrets.
/.kamal/secrets

# Playwright MCP artifacts.
/.playwright-mcp/

# Screenshot artifacts (E2E / QA captures — rebuilt locally).
# `manual/`, `beginner/`, `expert/` are content (referenced from README.md and
# E2E reports), keep them tracked. Other subdirs (after/, before/, error/,
# verify-*/, etc.) are local artifacts.
/docs/screenshots/*
!/docs/screenshots/manual/
!/docs/screenshots/beginner/
!/docs/screenshots/expert/

# Graphify knowledge graph output (rebuilt locally).
/graphify-out/

# IDE and AI tool local state.
.superpowers/
.worktrees/
.claire/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
.ruby-lsp/
.vscode/
.idea/

# OS files.
.DS_Store
Thumbs.db

