# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Bundler config.
/.bundle

# Environment files (keep .env.example as reference).
/.env*
!/.env.example

# Logs and temp files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Storage (uploaded files and SQLite databases in development).
/storage/*
!/storage/.keep

# Asset builds (Propshaft + TailwindCSS).
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Rails credentials key files.
/config/*.key

# Bootsnap cache.
/tmp/cache/bootsnap/

# Kamal deployment secrets.
/.kamal/secrets

# Playwright MCP artifacts.
/.playwright-mcp/

# IDE and AI tool local state.
.superpowers/
.worktrees/
.claude/
.ruby-lsp/
.vscode/
.idea/

# OS files.
.DS_Store
Thumbs.db
