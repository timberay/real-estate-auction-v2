<div>
  <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
    <%= @label %>
    <% if @required %>
      <span class="text-red-500">*</span>
    <% end %>
  </label>

  <% if @suffix.present? %>
    <div class="flex items-center gap-2">
      <%= tag.input(**input_attributes) %>
      <span class="text-slate-600 dark:text-slate-400"><%= @suffix %></span>
    </div>
  <% else %>
    <%= tag.input(**input_attributes) %>
  <% end %>

  <% if @error.present? %>
    <p class="text-sm text-red-600 dark:text-red-400 mt-1.5"><%= @error %></p>
  <% elsif @help_text.present? %>
    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1.5"><%= @help_text %></p>
  <% end %>
</div>
