<%= render CardComponent.new do |card| %>
  <div class="flex items-start justify-between">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <%= link_to @property.case_number, property_path(@property),
            class: "text-base font-semibold text-slate-900 dark:text-slate-100 hover:text-blue-600 dark:hover:text-blue-400" %>
        <% if @property.failed_bid_count.present? && @property.failed_bid_count >= 4 %>
          <span class="inline-flex items-center rounded bg-red-200 dark:bg-red-900/30 px-1.5 py-0.5 text-sm font-semibold text-red-700 dark:text-red-300">유찰 <%= @property.failed_bid_count %>회</span>
        <% elsif @property.failed_bid_count.present? && @property.failed_bid_count > 0 %>
          <span class="inline-flex items-center rounded bg-yellow-200 dark:bg-yellow-900/30 px-1.5 py-0.5 text-sm font-semibold text-yellow-700 dark:text-yellow-300">유찰 <%= @property.failed_bid_count %>회</span>
        <% else %>
          <span class="inline-flex items-center rounded bg-slate-200 dark:bg-slate-700 px-1.5 py-0.5 text-sm font-semibold text-slate-600 dark:text-slate-300">신건</span>
        <% end %>
        <% if @property.property_count > 1 %>
          <span class="inline-flex items-center rounded bg-amber-200 dark:bg-amber-900/30 px-1.5 py-0.5 text-sm font-semibold text-amber-700 dark:text-amber-300">다물건 <%= @property.property_count %>건</span>
        <% end %>
      </div>
      <div class="mt-1 flex items-center gap-1.5 flex-wrap">
        <%= render SafetyBadgeComponent.new(rating: @safety_rating) %>
        <% if @analyzed %>
          <%= render(BadgeComponent.new(variant: :accent)) { "AI 분석완료" } %>
        <% end %>
        <% if budget_exceeded? %>
          <%= render(BadgeComponent.new(variant: :warning)) { "예산 초과" } %>
        <% end %>
      </div>
      <% if @property.court_name.present? %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400 truncate" data-property-card="court">🏛️ <%= @property.court_name %></p>
      <% end %>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 truncate">📍 <%= @property.address %></p>
      <div class="mt-2 space-y-0.5">
        <div class="flex items-center justify-between text-sm" data-price-type="appraisal">
          <span class="relative text-slate-500 dark:text-slate-400 cursor-help"
                data-controller="tooltip"
                data-tooltip-content-value="감정평가사가 책정한 시장가치"
                data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
            감정가
            <svg class="inline w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
          <span class="font-medium text-slate-700 dark:text-slate-300"><%= formatted_price(@property.appraisal_price) %></span>
        </div>
        <div class="flex items-center justify-between text-sm" data-price-type="min-bid">
          <span class="relative text-slate-500 dark:text-slate-400 cursor-help"
                data-controller="tooltip"
                data-tooltip-content-value="법원이 정한 최소 입찰금액"
                data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
            최저매각가
            <svg class="inline w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
          <span class="font-medium text-slate-700 dark:text-slate-300"><%= formatted_price(@property.min_bid_price) %></span>
        </div>
        <% if (info = helpers.next_auction_schedule_info(@property)) %>
          <div class="flex items-center justify-between text-sm" data-property-card="next-auction">
            <span class="text-slate-500 dark:text-slate-400">다음 매각기일</span>
            <span class="flex items-center gap-1.5">
              <span class="font-medium text-slate-700 dark:text-slate-300"><%= info[:date].strftime("%Y.%m.%d") %></span>
              <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold <%= info[:dday_class] %>" aria-label="<%= info[:dday_aria] %>"><%= info[:dday_text] %></span>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-3 pt-3 border-t border-slate-200 dark:border-slate-700 flex items-center justify-between">
    <div class="relative" data-controller="overflow-menu">
      <button type="button"
              data-action="overflow-menu#toggle click@window->overflow-menu#closeIfOutside"
              data-overflow-menu-target="trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-label="<%= "#{@property.case_number} 더보기 메뉴" %>"
              class="inline-flex items-center justify-center w-8 h-8 rounded-md text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 transition-colors duration-150">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
        </svg>
      </button>
      <div data-overflow-menu-target="menu"
           hidden
           role="menu"
           class="absolute z-10 left-0 mt-1 w-44 rounded-md bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-lg py-1">
        <%= button_to property_path(@property),
            method: :delete,
            aria: { label: "#{@property.case_number} 삭제" },
            role: "menuitem",
            data: {
              turbo_confirm: "이 물건을 내 목록에서 삭제합니다.\n\n내 메모, AI 분석 결과, 권리 보고서가 함께 사라지고 되돌릴 수 없어요.\n\n계속하시겠습니까?"
            },
            form: { class: "block" },
            class: "flex w-full items-center gap-2 px-3 py-2 text-sm text-red-600 hover:bg-slate-50 dark:text-red-400 dark:hover:bg-slate-700/50 transition-colors duration-150" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          삭제
        <% end %>
      </div>
    </div>

    <% if @user_property %>
      <%= render FavoriteToggleComponent.new(user_property: @user_property) %>
    <% end %>
  </div>
<% end %>
