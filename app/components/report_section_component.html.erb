<section id="section-<%= anchor %>" class="scroll-mt-20">
  <div class="border-t border-slate-200 dark:border-slate-700 pt-6 pb-4">
    <div class="flex items-center gap-3">
      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-600 dark:bg-blue-500 text-sm font-bold text-white">
        <%= number %>
      </span>
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 break-keep"><%= title %></h2>
    </div>
    <% if show_beginner_summary? %>
      <p class="beginner-summary mt-2 ml-11 text-sm italic text-slate-600 dark:text-slate-400"><%= beginner_summary %></p>
    <% end %>
  </div>
  <div>
    <%= content %>
  </div>
</section>
