<div class="<%= CONTAINER_CLASSES %>">
  <% if @title.present? %>
    <div class="bg-slate-50 dark:bg-slate-800/80 border-b border-slate-200 dark:border-slate-700 px-4 py-3">
      <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300"><%= @title %></h2>
    </div>
  <% end %>

  <div class="divide-y divide-slate-200 dark:divide-slate-700">
    <% @rows.each do |row| %>
      <div class="<%= row_classes(row) %>">
        <span class="text-sm text-slate-600 dark:text-slate-400"><%= row[:label] %></span>
        <span class="text-sm text-slate-900 dark:text-slate-100 tabular-nums"><%= row[:value] %></span>
      </div>
    <% end %>
  </div>
</div>
