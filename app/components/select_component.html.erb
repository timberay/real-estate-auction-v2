<div>
  <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
    <%= @label %>
    <% if @required %>
      <span class="text-red-500">*</span>
    <% end %>
  </label>

  <select name="<%= @name %>" class="<%= select_classes %>"<%= " required" if @required %>>
    <% if @prompt.present? %>
      <option value=""><%= @prompt %></option>
    <% end %>
    <% option_items.each do |option| %>
      <option value="<%= option.value %>"<%= " selected" if option.selected %>><%= option.label %></option>
    <% end %>
  </select>

  <% if @error.present? %>
    <p class="text-sm text-red-600 dark:text-red-400 mt-1.5"><%= @error %></p>
  <% end %>
</div>
