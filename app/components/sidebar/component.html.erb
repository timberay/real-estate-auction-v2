<nav class="<%= NAV_CLASSES %>" data-sidebar-target="sidebar">
  <div class="flex flex-col py-4 h-full">
    <% if @current_user && !@current_user.guest? %>
      <%# Mobile-only budget indicator — the header hides its budget chip on
          < md, so we expose it here so the chip stays reachable via the
          hamburger menu. md:hidden prevents duplication on larger screens
          where the header copy is visible. %>
      <div class="px-2 pb-3 mb-3 border-b border-slate-200 dark:border-slate-700 md:hidden">
        <%= render "shared/budget_indicator", budget: @current_user.budget_setting %>
      </div>
    <% end %>
    <div class="flex-1 space-y-2 px-2 overflow-y-auto overflow-x-hidden">
      <% MENU_GROUPS.each do |group_title, items| %>
        <div>
          <div class="space-y-1">
            <% items.each do |item| %>
              <% if item.enabled %>
                <a href="<%= resolve_path(item) %>"
                   class="<%= item_classes(item) %>"
                   data-sidebar-item
                   title="<%= item.label %>">
                  <%= menu_icon(item.icon) %>
                  <span class="hidden lg:inline" data-sidebar-label><%= item.label %></span>
                </a>
              <% else %>
                <button type="button" disabled
                        class="<%= item_classes(item) %> w-full opacity-50"
                        data-sidebar-item
                        title="준비중">
                  <%= menu_icon(item.icon) %>
                  <span class="hidden lg:inline" data-sidebar-label>
                    <%= item.label %>
                    <span class="ml-1 text-sm font-medium text-slate-400 dark:text-slate-500">(준비중)</span>
                  </span>
                </button>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Toggle button %>
    <div class="border-t border-slate-200 dark:border-slate-700 px-2 py-2">
      <button type="button"
              class="flex items-center justify-center w-full p-2 rounded-md text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300 transition-colors duration-150"
              data-action="sidebar#toggle"
              aria-label="사이드바 접기/펼치기">
        <span data-sidebar-target="toggleIcon" class="transition-transform duration-200"><%= toggle_icon %></span>
      </button>
    </div>
  </div>
</nav>
