<div class="space-y-4"
     data-controller="source-doc-tracker source-doc-review"
     data-source-doc-review-url-value="<%= @review_url %>"
     data-source-doc-review-reviewed-value="<%= @source_doc_reviewed %>">
  <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">원문 뷰어</h3>

  <% if extraction_failed? %>
    <div class="rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 p-4 space-y-3">
      <div class="flex items-start gap-2">
        <span aria-hidden="true" class="text-amber-700 dark:text-amber-300 font-bold">!</span>
        <div class="flex-1">
          <p class="text-sm font-semibold text-amber-900 dark:text-amber-100">분석에 실패했습니다.</p>
          <% if failure_reason.present? %>
            <p class="mt-1 text-sm text-amber-800 dark:text-amber-200"><%= failure_reason %></p>
          <% end %>
          <p class="mt-1 text-xs text-amber-700 dark:text-amber-300">원본 문서를 참고하세요.</p>
        </div>
      </div>
      <% if retry_path %>
        <%= button_to "재시도", retry_path, method: :post,
                      data: { turbo: false },
                      class: "inline-flex items-center justify-center h-9 px-3 rounded-md bg-amber-600 dark:bg-amber-500 text-sm font-semibold text-white transition-colors hover:bg-amber-700 dark:hover:bg-amber-400 focus-visible:ring-2 focus-visible:ring-amber-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-amber-400/50 dark:focus-visible:ring-offset-slate-900" %>
      <% end %>
    </div>
  <% elsif !has_data? %>
    <div class="rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 p-4 text-sm text-slate-500 dark:text-slate-400">
      분석을 먼저 실행해주세요.
    </div>
  <% else %>
    <div class="flex border-b border-slate-200 dark:border-slate-700">
      <button class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600 dark:border-blue-400 dark:text-blue-400 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900"
              data-source-doc-tracker-target="tab" data-action="click->source-doc-tracker#switchTab click->source-doc-review#markReviewed"
              data-doc-type="court_auction">매각물건명세서</button>
      <button class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-slate-500 dark:text-slate-400 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900"
              data-source-doc-tracker-target="tab" data-action="click->source-doc-tracker#switchTab click->source-doc-review#markReviewed"
              data-doc-type="registry">등기부등본</button>
    </div>

    <div data-source-doc-tracker-target="panel" data-doc-type="court_auction"
         class="rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 p-4 text-sm font-mono leading-relaxed text-slate-700 dark:text-slate-300">
      <div class="font-semibold text-slate-900 dark:text-slate-100 mb-2">매각물건명세서 주요 내용</div>
      <p>• 말소기준권리: <%= @report.base_right_type.presence || "미확인" %> (<%= @report.base_right_holder.presence || "미확인" %>, <%= @report.base_right_date&.strftime("%Y.%m.%d") || "미확인" %>)</p>
      <p>• 종합 판단: <%= @report.verdict_summary.presence || "—" %></p>
      <p>• 인수 금액: <%= number_to_currency(@report.assumed_amount, unit: "₩", precision: 0) %></p>
      <p>• 위험 금액: <%= number_to_currency(@report.total_risk_amount, unit: "₩", precision: 0) %></p>
    </div>

    <div data-source-doc-tracker-target="panel" data-doc-type="registry" class="hidden rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 p-4 text-sm font-mono leading-relaxed text-slate-700 dark:text-slate-300">
      <div class="font-semibold text-slate-900 dark:text-slate-100 mb-2">등기부등본 주요 내용</div>
      <p>• 권리 설정: <%= rights_timeline.size %>건</p>
      <p>• 임차인: <%= tenants.size %>명 (대항력 있음: <%= tenants_with_opposing_power %>명)</p>
      <% if rights_timeline.any? %>
        <div class="mt-2 space-y-1">
          <% rights_timeline.each do |right| %>
            <p class="<%= right["extinguished_on_sale"] ? "text-slate-500 dark:text-slate-400" : "text-red-600 dark:text-red-400 font-semibold" %>">
              • <%= right["date"] %> <%= right["type"] %> — <%= right["holder"] %> (<%= number_to_currency(right["amount"], unit: "₩", precision: 0) %><%= " · #{right["amount_type"]}" if right["amount_type"].present? %>)
              <%= right["extinguished_on_sale"] ? "[소멸]" : "[인수]" %>
            </p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 px-3 py-2 text-sm text-red-800 dark:text-red-200">
    반드시 매각물건명세서 비고란을 직접 확인하세요. 본 서비스는 분석 결과의 정확성을 보증하지 않습니다.
  </div>
</div>
