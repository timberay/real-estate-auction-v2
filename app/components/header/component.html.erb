<header class="<%= HEADER_CLASSES %>">
  <div class="flex items-center gap-3">
    <button type="button" class="<%= BUTTON_CLASSES %> md:hidden" data-action="sidebar#toggleMobile" aria-label="메뉴 열기">
      <%= hamburger_icon %>
    </button>
    <span class="font-bold text-lg text-white"><%= @app_name %></span>
    <% if @page_title %>
      <span class="text-slate-500 hidden md:inline">/</span>
      <h1 id="page-title" class="text-sm font-medium text-slate-300 hidden md:inline"><%= @page_title %></h1>
    <% end %>
  </div>

  <div class="flex items-center gap-1">
    <%# C16: persistent help link so the manual / FAQ is one click away from
         every page (the sidebar isn't always open, especially on mobile).
         Icon visible on all viewports, label appears at sm+ to keep the
         mobile header from squeezing. %>
    <%= link_to helpers.manual_path,
        class: "#{BUTTON_CLASSES} inline-flex items-center gap-1",
        aria: { label: "도움말" },
        title: "도움말" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>
      </svg>
      <span class="hidden sm:inline text-sm">도움말</span>
    <% end %>

    <% if signed_in? %>
      <div class="hidden md:inline-flex">
        <%= render "shared/budget_indicator", budget: @current_user.budget_setting %>
      </div>
    <% end %>
    <div data-controller="dark-mode">
      <button type="button" class="<%= BUTTON_CLASSES %>" data-action="dark-mode#toggle" aria-label="다크 모드 전환">
        <span data-dark-mode-target="sunIcon"><%= sun_icon %></span>
        <span data-dark-mode-target="moonIcon" class="hidden"><%= moon_icon %></span>
      </button>
    </div>

    <% if @current_user %>
      <%= helpers.turbo_stream_from "user_#{@current_user.id}_notifications" %>
      <%= link_to notifications_path, class: "relative #{BUTTON_CLASSES}", aria: { label: "알림 #{unread_notification_count}건" } do %>
        <%= bell_icon %>
        <%= render partial: "notifications/badge", locals: { unread_count: unread_notification_count } %>
      <% end %>
    <% end %>

    <% if signed_in? %>
      <div class="relative" data-controller="dropdown" data-dropdown-open-value="false">
        <button type="button" class="<%= BUTTON_CLASSES %> flex items-center gap-2" data-action="dropdown#toggle" aria-label="사용자 메뉴">
          <% if @current_user.avatar_url.present? %>
            <img src="<%= @current_user.avatar_url %>" alt="" class="w-7 h-7 rounded-full">
          <% else %>
            <span class="w-7 h-7 rounded-full bg-slate-600 text-white text-xs flex items-center justify-center font-medium">
              <%= @current_user.name.to_s[0] %>
            </span>
          <% end %>
          <span class="hidden md:inline text-sm text-white"><%= @current_user.name %></span>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-44 bg-white dark:bg-slate-800 rounded-md shadow-lg border border-slate-200 dark:border-slate-700 py-1">
          <%= link_to "설정", settings_budget_path, class: "block px-4 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700" %>
          <%= button_to "로그아웃", auth_logout_path, method: :delete, form_class: "w-full",
              class: "block w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700" %>
        </div>
      </div>
    <% else %>
      <%= link_to "로그인", auth_login_path,
          class: "text-sm text-white hover:text-slate-200 px-3 py-2 rounded-md hover:bg-slate-700",
          data: { turbo_frame: "auth_modal" } %>
    <% end %>

    <span id="analysis_indicator"></span>
  </div>
</header>
