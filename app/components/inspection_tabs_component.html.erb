<%# Mobile (< sm): a single <select> avoids horizontal scroll on narrow viewports. %>
<div class="block sm:hidden mb-4" data-controller="tab-select">
  <select class="w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100"
          data-action="change->tab-select#navigate"
          aria-label="섹션 선택">
    <% tabs.each do |tab| %>
      <option value="<%= tab[:url] %>" <%= "selected" if tab[:active] %>>
        <%= mobile_option_label(tab) %>
      </option>
    <% end %>
  </select>
</div>

<%# Desktop (sm and up): keep the horizontal tab strip. %>
<nav id="inspection-tabs-nav" class="hidden sm:block mb-4 overflow-x-auto">
  <div class="flex items-center gap-1 text-sm min-w-max">
    <% tabs.each do |tab| %>
      <% if tab[:key] == "grade" %>
        <%# Separator: double chevron %>
        <div class="flex items-center ml-2">
          <svg class="w-5 h-5 text-slate-400 dark:text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
          <%= link_to tab[:url],
              class: "px-3 py-2 rounded-md transition-colors whitespace-nowrap font-semibold inline-flex items-center gap-1.5 #{grade_button_classes(tab)}" do %>
            <% if (badge = rating_badge(tab[:rating])) %>
              <span><%= badge[:label] %></span>
              <span class="opacity-70">·</span>
            <% end %>
            <span><%= tab[:label] %></span>
            <% if tab[:partial] %>
              <span class="text-sm font-normal opacity-80">(진행 중)</span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%= link_to tab[:url],
            class: "px-3 py-2 rounded-md transition-colors whitespace-nowrap #{tab[:active] ? 'bg-blue-600 text-white font-semibold dark:bg-blue-500' : 'bg-slate-100 text-slate-600 hover:bg-slate-200 hover:text-slate-900 dark:bg-slate-800 dark:text-slate-400 dark:hover:bg-slate-700 dark:hover:text-slate-200'}" do %>
          <% if (badge = rating_badge(tab[:rating])) %>
            <span class="<%= badge[:classes] %> text-sm font-semibold px-1.5 py-0.5 rounded"><%= badge[:label] %></span>
          <% end %>
          <span><%= tab[:label] %></span>
          <% if tab[:total] > 0 %>
            <span class="ml-1 text-sm <%= tab[:active] ? 'text-blue-200' : 'text-slate-400 dark:text-slate-500' %>"><%= tab[:checked] %>/<%= tab[:total] %></span>
            <% unanswered = tab[:total] - tab[:checked] %>
            <% if unanswered > 0 && tab[:rating] && tab[:rating] != :incomplete %>
              <span class="ml-1 bg-amber-400 text-amber-900 dark:bg-amber-500 dark:text-amber-950 text-sm font-bold px-1.5 py-0.5 rounded-full"><%= unanswered %></span>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</nav>
