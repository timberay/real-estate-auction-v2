<div>
  <%# Occupant type badge %>
  <% if occupant_type_label %>
    <div class="text-center mb-2">
      <span class="inline-flex items-center rounded-full px-4 py-1.5 text-sm font-semibold bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300">
        점유자 유형: <%= occupant_type_label %>
      </span>
    </div>
  <% end %>

  <%# Difficulty badge %>
  <div class="text-center mb-6">
    <%= render EvictionGuide::DifficultyBadgeComponent.new(level: @simulation.difficulty_level || "medium") %>
  </div>

  <%# Path visualization %>
  <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">명도 경로</h3>
  <div class="space-y-2 mb-6">
    <% @path.each do |entry| %>
      <% badge = status_badge(entry["status"]) %>
      <div class="flex items-center gap-3 text-sm">
        <span class="<%= badge[:classes] %> px-2 py-0.5 rounded text-sm font-medium whitespace-nowrap">
          <%= badge[:label] %>
        </span>
        <span class="text-slate-700 dark:text-slate-300">
          <%= entry["code"] %> <%= entry["name"] %>
        </span>
      </div>
    <% end %>
  </div>

  <%# Stats %>
  <div class="flex gap-4 mb-6">
    <div class="flex-1 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg text-center">
      <div class="text-sm text-slate-500 dark:text-slate-400">예상 총 단계</div>
      <div class="text-2xl font-bold text-slate-900 dark:text-slate-100"><%= total_steps %></div>
    </div>
    <div class="flex-1 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg text-center">
      <div class="text-sm text-slate-500 dark:text-slate-400">분기 진입</div>
      <div class="text-2xl font-bold text-slate-900 dark:text-slate-100"><%= branch_count %>건</div>
    </div>
  </div>

  <%# Disclaimer %>
  <div class="p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-sm text-red-800 dark:text-red-300 mb-6">
    이 결과는 시뮬레이션이며, 실제 명도 작업은 반드시 법률 전문가와 상담 후 진행하세요.
  </div>

  <%# Action CTAs %>
  <div class="flex flex-wrap items-center justify-end gap-3 print:hidden" data-controller="print">
    <button type="button"
            data-action="click->print#trigger"
            class="inline-flex items-center gap-2 h-10 px-4 text-sm font-medium rounded-md border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z"/></svg>
      인쇄
    </button>
    <%= link_to helpers.eviction_guide_simulator_path,
                class: "inline-flex items-center gap-2 h-10 px-4 text-sm font-medium rounded-md bg-blue-600 hover:bg-blue-700 text-white dark:bg-blue-500 dark:hover:bg-blue-400 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
      다시 시뮬레이션하기
    <% end %>
  </div>
</div>
