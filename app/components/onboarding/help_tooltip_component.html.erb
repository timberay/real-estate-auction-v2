<span class="relative inline-flex" data-controller="tooltip">
  <button type="button"
          class="ml-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-zinc-200 dark:bg-zinc-700 text-xs text-zinc-700 dark:text-zinc-300 hover:bg-zinc-300 dark:hover:bg-zinc-600"
          data-action="click->tooltip#toggle"
          aria-label="도움말">?</button>
  <span data-tooltip-target="content"
        class="hidden absolute z-10 left-6 top-0 w-72 rounded bg-zinc-800 p-2 text-xs text-white shadow-lg leading-relaxed">
    <%= @text %>
  </span>
</span>
