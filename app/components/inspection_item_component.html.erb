<div id="<%= dom_id(@result, "inspection_item") %>" class="rounded-lg border p-4 <%= risk_classes %><%= ' hidden' if @dependency_hidden %>"
     data-controller="inspection-item"
     data-inspection-item-result-id-value="<%= @result.id %>"
     data-inspection-item-auto-value="<%= auto_or_ai_source? && !ai_reference? %>"
     data-inspection-item-resolution-url-value="<%= property_inspections_result_resolution_path(@result.property, @result) %>"
     data-inspection-item-original-has-risk-value="<%= @result.has_risk.nil? ? '' : @result.has_risk %>"
     data-inspection-item-original-badge-text-value="<%= source_badge_text %>"
     data-inspection-item-original-badge-classes-value="<%= source_badge_classes %>"
     data-inspection-item-yes-means-safe-value="<%= @item.yes_means_safe? %>"
     data-item-code="<%= @item.code %>"
     <% if @item.depends_on.present? %>
     data-depends-on-code="<%= @item.depends_on['code'] %>"
     data-depends-on-show-when-risk="<%= @item.depends_on['show_when_risk'] %>"
     <% end %>>
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-2">
      <span class="inline-flex items-center rounded px-1.5 py-0.5 text-sm font-semibold <%= source_badge_classes %>"
            data-inspection-item-target="sourceBadge"><%= source_badge_text %></span>
      <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-mono text-slate-500 bg-slate-100 dark:bg-slate-800 dark:text-slate-400">
        <%= @item.code %>
      </span>
      <% if ai_reference? %>
        <span class="inline-flex items-center rounded px-1.5 py-0.5 text-sm font-semibold bg-amber-100 text-amber-700 ring-1 ring-inset ring-amber-600/20 dark:bg-amber-900/30 dark:text-amber-300 dark:ring-amber-400/20">직접 확인</span>
      <% end %>
      <p class="text-sm font-medium text-slate-900 dark:text-slate-100">
        <% if @beginner_mode %>
          <%= render Inspection::TermGlossaryComponent.new(text: @item.question) %>
        <% else %>
          <%= @item.question %>
        <% end %>
      </p>
    </div>
    <div class="ml-2 flex shrink-0 items-center gap-2">
      <span class="text-sm font-semibold <%= status_classes %>" data-inspection-item-target="statusLabel"><%= status_text %></span>
      <% if show_edit_mode? %>
        <button type="button"
                class="rounded border border-slate-400 px-2 py-0.5 text-sm text-slate-600 hover:bg-slate-100 dark:border-slate-500 dark:text-slate-300 dark:hover:bg-slate-700 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900"
                data-inspection-item-target="editButton"
                data-action="click->inspection-item#enterEditMode"><svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Z"/></svg>
수정</button>
        <button type="button"
                class="hidden rounded border border-slate-400 px-2 py-0.5 text-sm text-slate-600 hover:bg-slate-100 dark:border-slate-500 dark:text-slate-300 dark:hover:bg-slate-700 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900"
                data-inspection-item-target="cancelButton"
                data-action="click->inspection-item#cancelEditMode"><svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
취소</button>
      <% end %>
    </div>
  </div>
  <% if @item.description.present? %>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400"><%= @item.description %></p>
  <% end %>

  <% if logic_present? %>
    <div class="mt-2 space-y-1 text-sm" data-logic-section>
      <div class="flex items-start gap-1.5 rounded px-2 py-1 <%= logic_yes_classes %>"
           data-inspection-item-target="logicYes"
           <% if selected_answer == 'yes' %>data-logic-selected="yes"<% end %>>
        <span class="shrink-0" data-inspection-item-target="logicYesIcon"><%= selected_answer == "yes" ? "✔" : "○" %></span>
        <span>예 선택 시: <%= @item.logic["yes"] %></span>
      </div>
      <div class="flex items-start gap-1.5 rounded px-2 py-1 <%= logic_no_classes %>"
           data-inspection-item-target="logicNo"
           <% if selected_answer == 'no' %>data-logic-selected="no"<% end %>>
        <span class="shrink-0" data-inspection-item-target="logicNoIcon"><%= selected_answer == "no" ? "✔" : "○" %></span>
        <span>아니오 선택 시: <%= @item.logic["no"] %></span>
      </div>
    </div>
  <% end %>

  <% if evidence_present? %>
    <div class="mt-2.5 rounded-r-md border-l-3 p-2 px-3 text-sm <%= evidence_border_classes %>"
         data-evidence>
      <div class="font-semibold mb-1 <%= evidence_header_classes %>">📋 판정 근거 · <%= evidence["source_label"] %></div>
      <% if evidence["reasoning"].present? %>
        <div class="<%= evidence_label_classes %>"><span class="whitespace-pre-line <%= evidence_value_classes %>"><%= format_reasoning(evidence["reasoning"]) %></span></div>
      <% end %>
      <%= render(EvidenceLinkComponent.new(
        source_doc: evidence["source_doc"],
        page_number: evidence["page_number"],
        quote: evidence["quote"]
      )) %>
      <% if evidence["fields"].present? %>
        <% evidence["fields"].each do |field| %>
          <div class="<%= evidence_label_classes %>"><%= field["label"] %>: <span class="<%= evidence_value_classes %>"><%= field["value"] %></span></div>
        <% end %>
      <% end %>
      <% if evidence["keywords"].present? %>
        <div class="<%= evidence_label_classes %>">매칭 키워드: <span class="text-slate-300 dark:text-slate-300"><%= evidence["keywords"]["searched"].map { |k| "\"#{k}\"" }.join(", ") %></span></div>
        <div class="mt-0.5 <%= evidence_label_classes %>">결과: <span class="<%= keyword_result_classes %>"><%= evidence["keywords"]["found"] ? "발견" : "해당 없음" %></span></div>
      <% end %>
    </div>
  <% end %>

  <%# Edit mode: radio buttons for overriding AUTO answer (hidden by default) %>
  <% if show_edit_mode? %>
    <div class="mt-3 hidden border-t border-slate-200 dark:border-slate-600 pt-3"
         data-inspection-item-target="editSection">
      <p class="mb-2 text-sm font-medium text-slate-600 dark:text-slate-300">자동 수집 결과를 수정합니다:</p>
      <div class="flex items-center gap-4">
        <label class="inline-flex items-center text-sm text-slate-700 dark:text-slate-200">
          <%= radio_button_tag "resolutions[#{@result.id}][has_risk]", yes_radio_value, @result.has_risk == (yes_radio_value == "true"),
              disabled: true,
              data: { action: "change->inspection-item#toggleManualRisk", inspection_item_target: "overrideRadio" },
              class: "mr-1.5" %> <%= @item.yes_means_safe? ? "예 (안전)" : "예 (위험)" %>
        </label>
        <label class="inline-flex items-center text-sm text-slate-700 dark:text-slate-200">
          <%= radio_button_tag "resolutions[#{@result.id}][has_risk]", no_radio_value, @result.has_risk == (no_radio_value == "true"),
              disabled: true,
              data: { action: "change->inspection-item#toggleManualRisk", inspection_item_target: "overrideRadio" },
              class: "mr-1.5" %> <%= @item.yes_means_safe? ? "아니오 (위험)" : "아니오 (안전)" %>
        </label>
      </div>
      <%# Hidden field to signal this is an override %>
      <input type="hidden" name="resolutions[<%= @result.id %>][override]" value="true" disabled
             data-inspection-item-target="overrideFlag">
      <div data-inspection-item-target="overrideResolutionSection" class="hidden mt-3 rounded-md border border-dashed border-yellow-400 bg-yellow-50 dark:border-yellow-600 dark:bg-yellow-900/20 p-3">
        <p class="mb-2 text-sm font-medium text-yellow-800 dark:text-yellow-300">해결 가능 여부를 선택해주세요:</p>
        <div class="flex items-center gap-4">
          <label class="inline-flex items-center text-sm text-yellow-900 dark:text-yellow-200">
            <%= radio_button_tag "resolutions[#{@result.id}][resolvable]", "true", @result.resolvable == true,
                disabled: true,
                data: { inspection_item_target: "overrideRadio" },
                class: "mr-1.5" %> 해결 가능
          </label>
          <label class="inline-flex items-center text-sm text-yellow-900 dark:text-yellow-200">
            <%= radio_button_tag "resolutions[#{@result.id}][resolvable]", "false", @result.resolvable == false,
                disabled: true,
                data: { inspection_item_target: "overrideRadio" },
                class: "mr-1.5" %> 해결 불가
          </label>
        </div>
        <%= text_field_tag "resolutions[#{@result.id}][resolution_note]", @result.resolution_note,
            disabled: true,
            placeholder: "해결 방안 메모",
            data: { inspection_item_target: "overrideInput" },
            class: "mt-2 w-full h-10 rounded-md border border-yellow-400 dark:border-yellow-600 bg-white dark:bg-slate-700 px-3 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-colors" %>
      </div>
    </div>
  <% end %>

  <% if show_auto_resolution? %>
    <div class="mt-3 border-t border-slate-200 dark:border-slate-600 pt-3">
      <div class="flex items-center gap-4">
        <label class="inline-flex items-center text-sm text-slate-700 dark:text-slate-200">
          <%= radio_button_tag "resolutions[#{@result.id}][resolvable]", "true", @result.resolvable == true,
              data: { inspection_item_target: "resolvableRadio", action: "change->inspection-item#autosave" },
              class: "mr-1.5" %> 해결 가능
        </label>
        <label class="inline-flex items-center text-sm text-slate-700 dark:text-slate-200">
          <%= radio_button_tag "resolutions[#{@result.id}][resolvable]", "false", @result.resolvable == false,
              data: { inspection_item_target: "resolvableRadio", action: "change->inspection-item#autosave" },
              class: "mr-1.5" %> 해결 불가
        </label>
      </div>
      <%= text_field_tag "resolutions[#{@result.id}][resolution_note]", @result.resolution_note,
          placeholder: "해결 방안 메모",
          data: { inspection_item_target: "resolutionNote", action: "blur->inspection-item#autosave" },
          class: "mt-2 w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-200 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-colors" %>
    </div>
  <% end %>

  <% if show_manual_input? %>
    <div class="mt-3 border-t border-slate-200 dark:border-slate-600 pt-3">
      <div class="flex items-center gap-4 rounded-md bg-slate-50 dark:bg-slate-700/50 px-3 py-2">
        <label class="inline-flex items-center text-sm font-medium text-slate-800 dark:text-slate-100">
          <%= radio_button_tag "resolutions[#{@result.id}][has_risk]", yes_radio_value, @result.has_risk == (yes_radio_value == "true"),
              data: { action: "change->inspection-item#toggleManualRisk change->checklist-dependency#toggle change->inspection-item#autosave" }, class: "mr-1.5" %> 예
        </label>
        <label class="inline-flex items-center text-sm font-medium text-slate-800 dark:text-slate-100">
          <%= radio_button_tag "resolutions[#{@result.id}][has_risk]", no_radio_value, @result.has_risk == (no_radio_value == "true"),
              data: { action: "change->inspection-item#toggleManualRisk change->checklist-dependency#toggle change->inspection-item#autosave" }, class: "mr-1.5" %> 아니오
        </label>
      </div>
      <div data-inspection-item-target="resolutionSection" class="<%= 'hidden' unless @result.has_risk %> mt-3 rounded-md border border-dashed border-yellow-400 bg-yellow-50 dark:border-yellow-600 dark:bg-yellow-900/20 p-3">
        <p class="mb-2 text-sm font-medium text-yellow-800 dark:text-yellow-300">해결 가능 여부를 선택해주세요:</p>
        <div class="flex items-center gap-4">
          <label class="inline-flex items-center text-sm text-yellow-900 dark:text-yellow-200">
            <%= radio_button_tag "resolutions[#{@result.id}][resolvable]", "true", @result.resolvable == true,
                data: { inspection_item_target: "resolvableRadio", action: "change->inspection-item#autosave" },
                class: "mr-1.5" %> 해결 가능
          </label>
          <label class="inline-flex items-center text-sm text-yellow-900 dark:text-yellow-200">
            <%= radio_button_tag "resolutions[#{@result.id}][resolvable]", "false", @result.resolvable == false,
                data: { inspection_item_target: "resolvableRadio", action: "change->inspection-item#autosave" },
                class: "mr-1.5" %> 해결 불가
          </label>
        </div>
        <%= text_field_tag "resolutions[#{@result.id}][resolution_note]", @result.resolution_note,
            placeholder: "해결 방안 메모",
            data: { inspection_item_target: "resolutionNote", action: "blur->inspection-item#autosave" },
            class: "mt-2 w-full h-10 rounded-md border border-yellow-400 dark:border-yellow-600 bg-white dark:bg-slate-700 px-3 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
