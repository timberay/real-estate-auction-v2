<div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/30 p-6">
  <div class="flex items-start gap-6">
    <div class="shrink-0 space-y-3">
      <div class="text-center rounded-lg bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 p-3">
        <div class="text-sm text-slate-500 dark:text-slate-400">감정가</div>
        <div class="text-base font-bold text-slate-900 dark:text-slate-100"><%= format_price(@property.appraisal_price) %></div>
        <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">최저매각가</div>
        <div class="text-base font-semibold text-slate-900 dark:text-slate-100"><%= format_price(@property.min_bid_price) %></div>
      </div>
      <div class="text-center rounded-lg bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 p-3">
        <div class="text-sm text-slate-500 dark:text-slate-400">인수 금액</div>
        <div class="text-base font-bold text-slate-900 dark:text-slate-100"><%= format_price(@report.assumed_amount) %></div>
        <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">총 위험 금액</div>
        <div class="text-base font-semibold text-slate-900 dark:text-slate-100"><%= format_price(@report.total_risk_amount) %></div>
      </div>
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-2">핵심 근거</div>
      <div class="text-sm text-slate-700 dark:text-slate-300 whitespace-pre-line leading-relaxed"><%= @report.verdict_summary %></div>
      <div class="mt-3 text-sm">
        <span class="font-semibold text-slate-900 dark:text-slate-100">체크리스트 검토:</span>
        <span class="text-slate-600 dark:text-slate-400 break-words">
          <% if checklist_refs.any? %>
            <%= safe_join(checklist_refs.map { |ref|
              safe_join([
                content_tag(:span, "[#{ref[:code]}]", class: "font-mono text-xs"),
                " ",
                ref[:question] || "(삭제된 항목)"
              ])
            }, ", ") %>
          <% else %>
            위험 항목 없음
          <% end %>
        </span>
      </div>
    </div>
  </div>

  <% if @report.unevaluated_rights.any? %>
    <div class="rounded-md border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-400 p-4 my-4">
      <h3 class="font-semibold text-amber-900 dark:text-amber-100">
        ⚠️ 자동 계산 불가 권리 (<%= @report.unevaluated_rights.size %>건)
      </h3>
      <ul class="mt-2 list-disc pl-6 text-sm text-amber-900 dark:text-amber-200">
        <% @report.unevaluated_rights.each do |r| %>
          <li>
            <strong><%= r["type"] %></strong> — 별도 평가 필요. 본 도구는 채권액 합산에서 제외했습니다.
            <% if r["amount"].present? && r["amount"].to_i > 0 %>
              (참고 채권액: <%= format_price(r["amount"]) %>)
            <% end %>
          </li>
        <% end %>
      </ul>
      <p class="mt-2 text-xs text-amber-800 dark:text-amber-300"><%= @report.rights_disclaimer %></p>
    </div>
  <% end %>

  <% if show_simulator? %>
    <div class="mt-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white/60 dark:bg-slate-800/60 p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">예상 매각가 기준 임차인 미배당 잔액</h3>
        <span class="text-xs text-slate-500 dark:text-slate-400">⚠️ 추정치</span>
      </div>
      <div class="text-xs text-slate-600 dark:text-slate-400 mb-3">
        예상 매각가 <strong class="text-slate-900 dark:text-slate-100"><%= format_price(distribution_result.sale_price) %></strong>로 시뮬레이션 (집행비용 3% 차감 후 우선변제 순서대로 배당)
      </div>
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-slate-600 dark:text-slate-400 border-b border-slate-200 dark:border-slate-700">
            <th class="pr-3 pb-2 font-medium">임차인</th>
            <th class="pr-3 pb-2 font-medium text-right">보증금</th>
            <th class="pr-3 pb-2 font-medium text-right">예상 배당</th>
            <th class="pb-2 font-medium text-right">미배당 잔액</th>
          </tr>
        </thead>
        <tbody>
          <% distribution_result.tenant_outcomes.each do |t| %>
            <tr class="text-slate-700 dark:text-slate-300 border-b border-slate-100 dark:border-slate-800 last:border-b-0">
              <td class="pr-3 py-1">
                <%= t["name"] %>
                <% if t["opposing_power"] %>
                  <span class="ml-1 inline-flex items-center rounded bg-amber-100 dark:bg-amber-900/30 px-1.5 py-0.5 text-xs text-amber-800 dark:text-amber-200">대항력</span>
                <% end %>
              </td>
              <td class="pr-3 py-1 text-right tabular-nums"><%= format_price(t["deposit"]) %></td>
              <td class="pr-3 py-1 text-right tabular-nums"><%= format_price(t["dividend"]) %></td>
              <td class="py-1 text-right tabular-nums font-semibold <%= t["uncovered_remainder"].to_i.positive? ? "text-rose-700 dark:text-rose-300" : "text-slate-500 dark:text-slate-400" %>">
                <%= format_price(t["uncovered_remainder"]) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="mt-3 flex items-center justify-between rounded-md bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 px-3 py-2">
        <span class="text-sm font-medium text-rose-900 dark:text-rose-200">대항력 임차인 인수 부담 합계</span>
        <span class="text-sm font-bold text-rose-900 dark:text-rose-100 tabular-nums"><%= format_price(distribution_result.buyer_assumed_amount) %></span>
      </div>
      <p class="mt-2 text-xs text-slate-500 dark:text-slate-400 leading-relaxed"><%= distribution_result.disclaimer %></p>
    </div>
  <% end %>

  <% if opportunity? %>
    <div class="mt-4 flex items-center gap-2 rounded-lg bg-amber-100 dark:bg-amber-900/20 border border-amber-400 dark:border-amber-600 px-4 py-3">
      <span class="text-lg">💡</span>
      <div class="flex-1">
        <div class="text-sm font-semibold text-amber-800 dark:text-amber-200">안전 기회 물건</div>
        <div class="text-sm text-amber-700 dark:text-amber-300"><%= @report.opportunity_reason %></div>
      </div>
      <span class="text-sm text-amber-600 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-1 rounded">⚠️ 추정치</span>
    </div>
  <% end %>

  <div class="mt-4 text-sm text-slate-500 dark:text-slate-400">
    본 분석은 AI가 생성한 참고 자료이며, 법적 효력이 없습니다. 투자 판단에 따른 책임은 이용자 본인에게 있습니다.
  </div>
</div>
