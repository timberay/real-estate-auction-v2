<% content_for(:page_title, "명도 시뮬레이터") %>
<%= render EvictionGuide::TabNavigationComponent.new(active_tab: "simulator") %>

<div data-controller="simulator">
  <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-6">명도 시뮬레이터</h2>

  <%# Mode tabs %>
  <div class="border-b border-slate-200 dark:border-slate-700 mb-6">
    <nav class="-mb-px flex gap-x-4" aria-label="시뮬레이션 모드">
      <button type="button"
              data-simulator-target="propertyTab"
              data-action="simulator#showProperty"
              class="inline-flex items-center gap-1.5 whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium border-blue-500 text-blue-600 dark:text-blue-400">
        내 물건으로 시뮬레이션
      </button>
      <button type="button"
              data-simulator-target="manualTab"
              data-action="simulator#showManual"
              class="inline-flex items-center gap-1.5 whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300">
        직접 입력으로 시뮬레이션
      </button>
    </nav>
  </div>

  <%# Property selection panel %>
  <div data-simulator-target="propertyPanel">
    <% if @properties.any? %>
      <%= render "eviction_guide/simulator/property_selector", properties: @properties, selected_property: @property %>
    <% else %>
      <div class="mb-6 p-4 border border-dashed border-slate-300 dark:border-slate-600 rounded-lg text-sm text-slate-600 dark:text-slate-400">
        분석 완료된 물건이 없습니다.
        <%= link_to "AI 분석", new_analysis_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>을
        먼저 진행해 주세요.
      </div>
    <% end %>
  </div>

  <%# Manual entry panel %>
  <div data-simulator-target="manualPanel" class="hidden">
    <%= form_with url: eviction_guide_simulation_path, method: :post, class: "mb-6 p-4 border border-slate-200 dark:border-slate-700 rounded-lg" do |f| %>
      <%= f.hidden_field :property_id, value: "" %>
      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">물건 없이 상황을 직접 입력하여 시뮬레이션을 시작합니다.</p>
      <button type="submit"
              class="inline-flex items-center justify-center gap-2 h-10 px-4 text-sm font-medium rounded-md bg-blue-600 hover:bg-blue-700 text-white dark:bg-blue-500 dark:hover:bg-blue-400 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900">
        직접 입력으로 시작 →
      </button>
    <% end %>
  </div>

  <%# Guide reverse link %>
  <div class="p-3 bg-slate-50 dark:bg-slate-800 rounded-lg text-sm text-slate-600 dark:text-slate-400">
    명도 절차가 처음이라면
    <a href="<%= eviction_guide_guide_path %>" class="text-blue-600 dark:text-blue-400 hover:underline">명도 가이드</a>를
    먼저 읽어보세요.
  </div>
</div>
