<div class="mb-6 p-4 border border-slate-200 dark:border-slate-700 rounded-lg"
     data-simulator-target="propertySelector">
  <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-3">물건 선택</h3>
  <%= form_with url: eviction_guide_simulation_path, method: :post do |f| %>
    <div class="mb-3">
      <label for="property_id" class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5 block">분석 완료된 물건</label>
      <%= f.select :property_id,
            properties.map { |p| ["#{p.case_number} — #{p.address}", p.id] },
            { include_blank: "물건을 선택하세요" },
            class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:focus:ring-blue-400/20 focus:border-blue-500 dark:focus:border-blue-400 transition-colors duration-150" %>
    </div>
    <button type="submit"
            class="inline-flex items-center justify-center gap-2 h-10 px-4 text-sm font-medium rounded-md bg-blue-600 hover:bg-blue-700 text-white dark:bg-blue-500 dark:hover:bg-blue-400 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900">
      선택 완료 → 시뮬레이션 시작
    </button>
  <% end %>
</div>
