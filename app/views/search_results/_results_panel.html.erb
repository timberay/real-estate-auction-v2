<%# Locals:
      search_results          — relation/array of SearchResult (paginated, may be empty)
      search_page             — Integer (1-based)
      total_pages             — Integer
      api_total_count         — Integer or nil
      over_api_limit          — Boolean
      existing_case_numbers   — Set of case_number strings
%>
<div id="criteria-search-results">
  <% if search_results&.any? %>
    <%= render "search_results/inline_results",
               search_results: search_results,
               search_page: search_page,
               total_pages: total_pages,
               api_total_count: api_total_count,
               over_api_limit: over_api_limit,
               existing_case_numbers: existing_case_numbers %>
  <% end %>
</div>
