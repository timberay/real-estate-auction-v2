<%# app/views/search_results/_criteria_preview_popup.html.erb %>
<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" data-action="click->criteria-search#closeDebug">
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-200 dark:border-slate-700 p-5 max-w-sm w-full mx-4" data-action="click->criteria-search#stopPropagation">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">검색 조건 확인</h3>
      <button type="button" data-action="click->criteria-search#closeDebug"
              class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 text-lg leading-none">&times;</button>
    </div>
    <dl class="space-y-2 text-sm">
      <div class="flex justify-between">
        <dt class="text-slate-500 dark:text-slate-400">지역</dt>
        <dd class="font-medium text-slate-900 dark:text-slate-100"><%= criteria[:region] %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-slate-500 dark:text-slate-400">연도</dt>
        <dd class="font-medium text-slate-900 dark:text-slate-100"><%= criteria[:year] %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-slate-500 dark:text-slate-400">최소 금액</dt>
        <dd class="font-medium text-slate-900 dark:text-slate-100"><%= format_price_won(criteria[:min_price]) %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-slate-500 dark:text-slate-400">최대 금액</dt>
        <dd class="font-medium text-slate-900 dark:text-slate-100"><%= format_price_won(criteria[:max_price]) %></dd>
      </div>
    </dl>
    <div class="flex items-center gap-2 mt-5">
      <%= form_with url: search_results_path, method: :post, class: "flex-1", data: { turbo_stream: true, action: "submit->criteria-search#startSearch turbo:submit-end->criteria-search#enable" } do %>
        <button type="submit" data-criteria-search-target="searchButton"
                class="w-full inline-flex items-center justify-center gap-1.5 h-9 rounded-md bg-violet-600 hover:bg-violet-700 dark:bg-violet-600 dark:hover:bg-violet-500 text-white text-sm font-medium transition-colors">
          <span data-criteria-search-target="searchButtonText">검색 실행</span>
          <svg data-criteria-search-target="searchButtonSpinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      <% end %>
      <button type="button" data-action="click->criteria-search#closeDebug"
              class="flex-1 h-9 rounded-md border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
        취소
      </button>
    </div>
  </div>
</div>
