<%# app/views/analyses/manual_inputs/edit.html.erb %>
<%= turbo_frame_tag "analysis_flow" do %>
  <div class="space-y-6" data-controller="manual-input">
    <div>
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">수동 입력이 필요한 항목</h2>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">API에서 자동으로 확인할 수 없는 항목입니다. 직접 확인 후 입력해주세요.</p>
    </div>

    <% if @pending_results.empty? %>
      <p class="text-sm text-slate-600 dark:text-slate-400">수동 입력이 필요한 항목이 없습니다.</p>
      <%= link_to "결과 확인", edit_property_analyses_result_path(@property),
          class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
    <% else %>
      <%= form_with url: property_analyses_manual_input_path(@property), method: :patch do |f| %>
        <div class="space-y-4">
          <% @pending_results.each do |result| %>
            <div class="rounded-lg border border-slate-200 dark:border-slate-700 p-4" data-manual-input-target="radioGroup">
              <p class="text-sm font-medium text-slate-900 dark:text-slate-100 mb-1"><%= result.checklist_item.question %></p>
              <% if result.checklist_item.description.present? %>
                <p class="text-xs text-slate-500 dark:text-slate-400 mb-3"><%= result.checklist_item.description %></p>
              <% end %>
              <%= hidden_field_tag "check_results[#{result.id}][manual_value]", "" %>
              <div class="flex items-center gap-4">
                <label class="inline-flex items-center text-sm text-slate-700 dark:text-slate-300">
                  <%= radio_button_tag "check_results[#{result.id}][has_risk]", "true", false,
                      data: { action: "change->manual-input#validate" }, class: "mr-1.5 text-red-600" %> 예 (위험)
                </label>
                <label class="inline-flex items-center text-sm text-slate-700 dark:text-slate-300">
                  <%= radio_button_tag "check_results[#{result.id}][has_risk]", "false", false,
                      data: { action: "change->manual-input#validate" }, class: "mr-1.5 text-green-600" %> 아니오 (안전)
                </label>
              </div>
            </div>
          <% end %>
        </div>
        <div class="mt-6">
          <%= f.submit "완료",
              class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
              data: { manual_input_target: "submitButton" },
              disabled: true %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
