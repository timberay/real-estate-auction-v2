<% content_for(:page_title, "AI 분석 이력") %>

<div class="space-y-4">
  <div class="flex items-center gap-2">
    <%= link_to "← 매물 상세", property_path(@property), class: "text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300" %>
  </div>

  <%= render CardComponent.new(title: "AI 분석 이력") do %>
    <div class="space-y-3">
      <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-300">
        <span class="font-medium"><%= [@property.court_name.presence, @property.case_number].compact.join(" ") %></span>
        <% if @property.address.present? %>
          <span class="text-slate-400 dark:text-slate-500">|</span>
          <span class="truncate"><%= @property.address %></span>
        <% end %>
      </div>

      <% if @logs.empty? %>
        <p class="text-sm text-slate-500 dark:text-slate-400 py-6 text-center">
          분석 이력이 없습니다.
        </p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm" data-testid="llm-history-table">
            <thead class="text-xs uppercase text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-700">
              <tr>
                <th scope="col" class="py-2 pr-4 text-left font-medium">실행 시각</th>
                <th scope="col" class="py-2 pr-4 text-left font-medium">제공자</th>
                <th scope="col" class="py-2 pr-4 text-left font-medium">모델</th>
                <th scope="col" class="py-2 pr-4 text-left font-medium">상태</th>
                <th scope="col" class="py-2 pr-4 text-left font-medium">오류</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
              <% @logs.each do |log| %>
                <tr data-testid="llm-history-row">
                  <td class="py-2 pr-4 whitespace-nowrap text-slate-700 dark:text-slate-300">
                    <% if (ts = log.executed_at || log.created_at) %>
                      <%= ts.strftime("%Y.%m.%d %H:%M") %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td class="py-2 pr-4 text-slate-700 dark:text-slate-300">
                    <%= log.provider.presence || "—" %>
                  </td>
                  <td class="py-2 pr-4 text-slate-700 dark:text-slate-300">
                    <%= log.model.presence || "—" %>
                  </td>
                  <td class="py-2 pr-4">
                    <% case log.status
                       when "completed" %>
                      <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300"><%= log.status_label %></span>
                    <% when "failed" %>
                      <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300"><%= log.status_label %></span>
                    <% else %>
                      <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-semibold bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200"><%= log.status_label %></span>
                    <% end %>
                  </td>
                  <td class="py-2 pr-4 text-slate-500 dark:text-slate-400 max-w-xs truncate" title="<%= log.error_message %>">
                    <%= log.error_message.present? ? truncate(log.error_message, length: 80) : "—" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
