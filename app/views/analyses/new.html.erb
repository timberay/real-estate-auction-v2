<% content_for(:page_title, "AI분석") %>

<div class="space-y-4" data-controller="analysis-tabs" data-analysis-tabs-prompt-url-value="<%= prompt_analyses_path %>">
  <% if @property %>
    <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
      <span class="font-medium text-slate-700 dark:text-slate-300">
        <% if @property.court_name.present? %><%= @property.court_name %> <% end %><%= @property.case_number %>
      </span>
      <% if @property.address.present? %>
        <span class="text-slate-400 dark:text-slate-500">|</span>
        <span class="truncate"><%= @property.address %></span>
      <% end %>
    </div>
  <% end %>

  <div class="border-b border-slate-200 dark:border-slate-700">
    <nav class="-mb-px flex gap-x-4" aria-label="Tabs">
      <button type="button"
        data-analysis-tabs-target="autoTab"
        class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium border-slate-200 text-slate-400 dark:border-slate-700 dark:text-slate-500 opacity-60 cursor-not-allowed"
        disabled
        aria-disabled="true"
        title="현재 일시 중단됨. 수동분석을 이용해 주세요.">
        AI 자동분석
        <span class="ml-1 inline-flex items-center rounded bg-zinc-300 dark:bg-zinc-700 px-1.5 py-0.5 text-xs">
          일시 중단
        </span>
      </button>
      <button type="button"
        data-analysis-tabs-target="manualTab"
        data-action="click->analysis-tabs#showManual"
        class="whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium border-blue-500 text-blue-600 dark:text-blue-400">
        AI 수동분석
      </button>
    </nav>
  </div>

  <div data-analysis-tabs-target="autoPanel" class="hidden">
    <div class="rounded border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800/50 p-6">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 mb-2">AI 자동분석은 현재 일시 중단 상태입니다</h2>
      <p class="text-sm text-slate-700 dark:text-slate-300 mb-4">
        외부 LLM API 호출에 따른 과금 문제로 자동분석 기능이 일시 중단되었습니다.
        아래의 <strong>AI 수동분석</strong> 탭을 이용해 주세요.
      </p>
    </div>
  </div>

  <div data-analysis-tabs-target="manualPanel">
    <%= render LlmDataDisclosureComponent.new %>
    <%= render "analyses/manual_form" %>
  </div>
</div>
