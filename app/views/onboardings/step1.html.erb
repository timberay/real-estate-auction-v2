<turbo-frame id="onboarding_wizard">
  <div class="container mx-auto px-4 py-8 max-w-lg">
    <h1 class="text-2xl font-bold mb-6">투자 가능한 유용자금을 입력하세요</h1>
    <p class="text-gray-500 text-sm mb-6">유용자금이란 현재 투자에 사용할 수 있는 현금을 말합니다</p>

    <%= form_with model: @setting, url: step1_onboarding_path, method: :post, data: { turbo_frame: "onboarding_wizard" } do |f| %>
      <% if @setting.errors[:available_cash].any? %>
        <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm">
          <%= @setting.errors[:available_cash].join(", ") %>
        </div>
      <% end %>

      <div class="mb-6" data-controller="number-format" data-number-format-initial-value="<%= @setting.available_cash || 3000 %>">
        <label for="available_cash_display" class="block text-sm font-medium text-gray-700 mb-2">유용자금</label>
        <div class="flex items-center gap-2">
          <input type="text" id="available_cash_display"
            inputmode="numeric"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg"
            placeholder="3,000"
            data-number-format-target="display"
            data-action="input->number-format#format">
          <%= f.hidden_field :available_cash, data: { number_format_target: "hidden" } %>
          <span class="text-gray-600 font-medium whitespace-nowrap">만원</span>
        </div>
      </div>

      <div class="mt-8">
        <%= f.submit "다음",
          class: "w-full bg-blue-600 text-white py-3 px-6 rounded-lg font-semibold hover:bg-blue-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</turbo-frame>
