<div class="max-w-lg mx-auto">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-2">예산 설정 완료</h1>
    <p class="text-slate-500 dark:text-slate-400">나의 최대 입찰 가능 금액이 계산되었습니다</p>
  </div>

  <% if @setting %>
    <%= render StatCardComponent.new(
      label: "최대 입찰가",
      value: format_price_in_eok(@setting.max_bid_amount)
    ) %>


    <div class="mt-6">
      <%= render SummaryTableComponent.new(
        title: "비용 내역",
        rows: [
          { label: "쓸 수 있는 현금", value: format_price_in_eok(@setting.available_cash) },
          { label: "수선비", value: format_price_in_eok(@setting.repair_cost) },
          { label: "취득세", value: format_price_in_eok(@setting.acquisition_tax) },
          { label: "법무사비", value: format_price_in_eok(@setting.scrivener_fee) },
          { label: "이사비", value: format_price_in_eok(@setting.moving_cost) },
          { label: "관리비", value: format_price_in_eok(@setting.maintenance_fee) },
          { label: "예비비 합계", value: format_price_in_eok(@setting.total_reserves), highlight: true },
          { label: "대출 비율 (LTV)", value: "#{(@setting.loan_ratio.to_f * 100).round}%" }
        ]
      ) %>
    </div>

    <% if (basis = tax_basis_line(@setting)) %>
      <p class="text-xs text-slate-500 dark:text-slate-400 text-center mt-2"><%= basis %></p>
    <% end %>

    <p class="text-sm text-slate-400 dark:text-slate-500 text-center mt-4 mb-6">
      적용 정책: <%= @setting.loan_policy&.policy_name || "직접 설정" %>
    </p>

    <div class="mt-6 space-y-3">
      <%# C6: send users straight to the search page after onboarding so they
            can take the next action without bouncing through the home redirect. %>
      <%= render ButtonComponent.new(tag: :a, href: search_path, icon: "magnifying-glass", class: "w-full justify-center") do %>
        물건 찾으러 가기
      <% end %>
      <%= render ButtonComponent.new(variant: :outline, tag: :a, href: settings_budget_path, icon: "cog-6-tooth", class: "w-full justify-center") do %>
        설정 다시 하기
      <% end %>
    </div>
  <% end %>
</div>
