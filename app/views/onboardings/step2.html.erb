<turbo-frame id="onboarding_wizard">
  <%= render WizardStepComponent.new(
    title: "예비비 설정",
    description: "부동산 유형과 면적에 따라 예비비가 자동 계산됩니다",
    current_step: 2,
    total_steps: 3
  ) do %>
    <div data-controller="reserve-fund"
         data-reserve-fund-defaults-value="<%= @reserve_defaults.to_json %>"
         data-reserve-fund-available-cash-value="<%= @setting.available_cash.to_i %>"
         data-reserve-fund-tax-brackets-value="<%= @tax_brackets.to_json %>"
         data-reserve-fund-loan-ratio-value="<%= @setting.loan_ratio.to_f.zero? ? 0.7 : @setting.loan_ratio.to_f %>"
         data-reserve-fund-acquisition-tax-auto-value="<%= @setting.acquisition_tax_auto %>"
         data-reserve-fund-precise-mode-value="<%= @setting.acquisition_tax_precise_mode %>"
         data-reserve-fund-area-over-85-value="<%= @setting.area_over_85? %>">
      <%= form_with model: @setting, url: step2_onboarding_path, method: :post, data: { turbo_frame: "onboarding_wizard" } do |f| %>
        <%# 부동산 유형 %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">부동산 유형</label>
          <%= f.collection_select :property_type_id, @property_types, :id, :name,
            { prompt: "선택하세요" },
            { class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
              data: { reserve_fund_target: "propertyType",
                      action: "change->reserve-fund#propertyTypeChanged" } } %>
        </div>

        <%# 관심 면적 %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">관심 면적</label>
          <%= select_tag "budget_setting[area_category]",
            options_for_select(BudgetSetting.area_category_options, @setting.selected_area_category),
            prompt: "선택하세요",
            class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
            data: { reserve_fund_target: "areaCategory",
                    action: "change->reserve-fund#areaChanged" } %>
        </div>

        <%# 주택 보유 상태 — 취득세율을 결정하는 핵심 입력 %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
            <span class="relative inline-flex items-center gap-1 cursor-help"
                  data-controller="tooltip"
                  data-tooltip-content-value="주택 수가 많을수록 취득세율이 높아집니다 (조정대상지역 2주택 8.4%, 3주택+ 12.4%)"
                  data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
              주택 보유
              <svg class="inline w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </span>
          </label>
          <%= f.select :household_tier, @household_tier_options,
            {},
            { class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
              data: { reserve_fund_target: "householdTier",
                      action: "change->reserve-fund#householdTierChanged" } } %>
        </div>

        <%# 자동 계산 토글 %>
        <div class="mb-4">
          <label class="flex items-center gap-2">
            <input type="checkbox" checked
                   data-reserve-fund-target="autoCalc"
                   data-action="change->reserve-fund#toggleAutoCalc"
                   class="rounded border-slate-300 dark:border-slate-600 text-blue-600 focus:ring-blue-500">
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">면적/유형에 따라 자동 계산</span>
          </label>
          <p class="text-sm text-slate-400 dark:text-slate-500 mt-1 ml-6">체크 해제 시 직접 입력할 수 있습니다</p>
        </div>

        <%# 자동 모드 플래그 — Stimulus가 체크박스 변화에 맞춰 토글 %>
        <%= f.hidden_field :acquisition_tax_auto, value: @setting.acquisition_tax_auto, data: { reserve_fund_target: "acquisitionTaxAuto" } %>

        <%# 예비비 항목 %>
        <div class="space-y-3">
          <% [
            [:repair_cost, "수선비", "repairCost", "평균면적 기준 수선비", "낙찰 후 집을 사용 가능한 상태로 만드는 데 드는 평균 비용"],
            [:acquisition_tax, "취득세", "acquisitionTax", "취득세율 적용", "낙찰 가격의 1.1~3.5%를 등기할 때 세금으로 납부"],
            [:scrivener_fee, "법무사비", "scrivenerFee", "등기 대행 비용", "등기를 대신 처리해 주는 법무사 수수료 (선택)"],
            [:moving_cost, "이사비", "movingCost", "면적 기준 이사비", "기존 점유자가 나가는 데 드는 합의금 (명도비)"],
            [:maintenance_fee, "미납 관리비", "maintenanceFee", "미납 관리비 (없으면 0)", "이전 소유자가 안 낸 관리비를 낙찰자가 부담하는 경우"]
          ].each do |field, label, target, hint_default, tooltip| %>
            <div>
              <div class="flex items-center gap-2">
                <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300 shrink-0">
                  <span class="relative inline-flex items-center gap-1 cursor-help"
                        data-controller="tooltip"
                        data-tooltip-content-value="<%= tooltip %>"
                        data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
                    <%= label %>
                    <svg class="inline w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </span>
                </label>
                <%= f.number_field field, inputmode: "numeric",
                  class: "flex-1 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                  data: { reserve_fund_target: target,
                          reserve_fund_readonly_when_auto: (field == :acquisition_tax).to_s,
                          action: "input->reserve-fund#updateTotal" } %>
                <span class="text-slate-600 dark:text-slate-400 text-sm whitespace-nowrap">만원</span>
              </div>
              <p class="ml-24 pl-2 mt-1 text-sm text-slate-400 dark:text-slate-500"
                 data-reserve-fund-target="<%= target %>Hint"><%= hint_default %></p>
            </div>
          <% end %>
        </div>

        <%# 합계 + 쓸 수 있는 현금 비교 %>
        <div class="mt-4 p-3 rounded-lg border transition-colors"
             data-reserve-fund-target="summaryBox">
          <div class="flex justify-between items-center">
            <p class="text-sm font-medium text-slate-700 dark:text-slate-300">
              예비비 합계: <span class="tabular-nums" data-reserve-fund-target="total">0</span>만원
            </p>
            <p class="text-sm text-slate-500 dark:text-slate-400">
              쓸 수 있는 현금: <span class="tabular-nums"><%= number_with_delimiter(@setting.available_cash.to_i) %></span>만원
            </p>
          </div>
          <p class="mt-1 text-sm text-red-600 dark:text-red-400 hidden" data-reserve-fund-target="warning">
            예비비가 쓸 수 있는 현금을 초과합니다. 예비비를 조정해 주세요.
          </p>
        </div>

        <%# 네비게이션 %>
        <div class="mt-8 flex gap-4">
          <%= render ButtonComponent.new(variant: :outline, tag: :a, href: start_onboarding_path, icon: "arrow-left", data: { turbo_frame: "onboarding_wizard" }, class: "flex-1 justify-center") { "이전" } %>
          <button type="submit"
                  data-reserve-fund-target="submitBtn"
                  class="flex-1 justify-center inline-flex items-center gap-2 font-medium rounded-md transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 bg-blue-600 hover:bg-blue-700 text-white dark:bg-blue-500 dark:hover:bg-blue-400 h-10 px-4 text-base">
            <%= raw Heroicon::Icon.render(name: "arrow-right", variant: :outline, options: { class: "w-5 h-5" }, path_options: {}) %>
            다음
          </button>
        </div>
      <% end %>
    </div>
  <% end %>
</turbo-frame>
