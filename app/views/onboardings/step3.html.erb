<turbo-frame id="onboarding_wizard">
  <div class="container mx-auto px-4 py-8 max-w-lg"
       data-controller="loan-slider failed-rounds"
       data-loan-slider-available-cash-value="<%= @setting.available_cash %>"
       data-loan-slider-total-reserves-value="<%= @setting.total_reserves %>">
    <h1 class="text-2xl font-bold mb-6">대출 및 낙찰가 설정</h1>

    <%= form_with model: @setting, url: step3_onboarding_path, method: :post, data: { turbo_frame: "onboarding_wizard" } do |f| %>
      <% if @setting.errors.any? %>
        <div class="mb-4 p-3 bg-red-50 text-red-700 rounded-lg text-sm">
          <% @setting.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-3">대출 정책 선택</label>
        <div class="space-y-2">
          <% if @loan_policies.present? %>
            <% @loan_policies.each do |policy| %>
              <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer">
                <%= f.radio_button :loan_policy_id, policy.id,
                  data: { loan_ratio: policy.loan_ratio, action: "change->loan-slider#selectPolicy" },
                  class: "text-blue-600" %>
                <div>
                  <span class="font-medium"><%= policy.policy_name %></span>
                  <span class="text-sm text-gray-500 ml-2">LTV <%= (policy.loan_ratio * 100).to_i %>%</span>
                  <% if policy.description.present? %>
                    <p class="text-xs text-gray-400 mt-1"><%= policy.description %></p>
                  <% end %>
                </div>
              </label>
            <% end %>
          <% else %>
            <p class="text-gray-500 text-sm">선택한 부동산 유형에 해당하는 대출 정책이 없습니다.</p>
          <% end %>
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">대출 비율 (LTV)</label>
        <input type="range" min="0" max="90" step="5"
               value="<%= (@setting.loan_ratio.to_f * 100).to_i %>"
               class="w-full"
               data-loan-slider-target="slider"
               data-action="input->loan-slider#slide">
        <div class="flex justify-between text-sm text-gray-500 mt-1">
          <span>0%</span>
          <span data-loan-slider-target="ratioDisplay"><%= (@setting.loan_ratio.to_f * 100).to_i %>%</span>
          <span>90%</span>
        </div>
        <input type="hidden" name="budget_setting[loan_ratio]" data-loan-slider-target="hiddenRatio" value="<%= @setting.loan_ratio %>">
      </div>

      <div class="mb-6 p-4 bg-blue-50 rounded-lg">
        <p class="text-sm text-gray-600">예상 최대입찰가</p>
        <p class="text-2xl font-bold text-blue-700" data-loan-slider-target="maxBidPreview">계산 중...</p>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">유찰 회차</label>
        <input type="range" min="0" max="3" step="1"
               value="<%= @setting.failed_auction_rounds %>"
               name="budget_setting[failed_auction_rounds]"
               class="w-full"
               data-failed-rounds-target="slider"
               data-action="input->failed-rounds#slide">
        <div class="flex justify-between text-sm text-gray-500 mt-1">
          <span>0회차 (신건)</span>
          <span data-failed-rounds-target="roundsDisplay"><%= @setting.failed_auction_rounds %>회차</span>
          <span>3회차</span>
        </div>
      </div>

      <div class="mb-6 p-4 bg-gray-50 rounded-lg">
        <p class="text-sm text-gray-600">검색 가능 감정가 상한</p>
        <p class="text-xl font-bold text-gray-700" data-failed-rounds-target="limitPreview">계산 중...</p>
      </div>

      <p class="text-xs text-gray-400 mb-6">
        ※ 이 계산은 추정치입니다. 정확한 대출 한도는 금융기관에 확인하세요.
      </p>

      <div class="mt-8 flex gap-4">
        <%= link_to "이전", start_onboarding_path,
          class: "flex-1 text-center py-3 px-6 border border-gray-300 rounded-lg font-semibold text-gray-700 hover:bg-gray-50 transition-colors",
          data: { turbo_frame: "onboarding_wizard" } %>
        <%= f.submit "계산하기",
          class: "flex-1 bg-blue-600 text-white py-3 px-6 rounded-lg font-semibold hover:bg-blue-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</turbo-frame>
