<span id="notification_badge" data-testid="notification-badge">
  <% if unread_count.to_i > 0 %>
    <span class="absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-semibold leading-none"
          aria-label="<%= unread_count %>건의 새 알림">
      <%= unread_count > 99 ? "99+" : unread_count %>
    </span>
  <% end %>
</span>
