<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">스냅샷 비교</h1>
    <%= link_to "목록으로", settings_budget_snapshots_path,
      class: "text-blue-600 text-sm underline" %>
  </div>

  <div class="flex gap-4 mb-6">
    <div class="flex-1 p-3 bg-gray-50 rounded-lg text-center">
      <p class="text-xs text-gray-500">기준</p>
      <p class="font-semibold">v<%= @snapshot_a.version %> (<%= @snapshot_a.trigger %>)</p>
      <p class="text-xs text-gray-400"><%= @snapshot_a.calculated_at&.strftime("%Y-%m-%d") %></p>
    </div>
    <div class="flex items-center text-gray-400">vs</div>
    <div class="flex-1 p-3 bg-gray-50 rounded-lg text-center">
      <p class="text-xs text-gray-500">비교 대상</p>
      <p class="font-semibold">v<%= @snapshot_b.version %> (<%= @snapshot_b.trigger %>)</p>
      <p class="text-xs text-gray-400"><%= @snapshot_b.calculated_at&.strftime("%Y-%m-%d") %></p>
    </div>
  </div>

  <% if @diff.empty? %>
    <div class="p-6 bg-gray-50 rounded-lg text-center">
      <p class="text-gray-500">두 스냅샷의 값이 동일합니다.</p>
    </div>
  <% else %>
    <%
      field_labels = {
        available_cash: "유용자금",
        repair_cost: "수선비",
        acquisition_tax: "취득세",
        scrivener_fee: "법무사비",
        moving_cost: "이사비",
        maintenance_fee: "관리비",
        loan_ratio: "대출 비율",
        max_bid_amount: "최대입찰가",
        failed_auction_rounds: "유찰 회차",
        searchable_appraisal_limit: "검색 가능 감정가"
      }
    %>
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-700">항목</th>
            <th class="px-4 py-3 text-right text-sm font-medium text-gray-700">기존</th>
            <th class="px-4 py-3 text-right text-sm font-medium text-gray-700">변경</th>
            <th class="px-4 py-3 text-right text-sm font-medium text-gray-700">차이</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @diff.each do |field, change| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-600"><%= field_labels[field] || field %></td>
              <td class="px-4 py-3 text-sm text-right font-medium">
                <% if field == :loan_ratio %>
                  <%= "#{(change[:was].to_f * 100).round}%" %>
                <% else %>
                  <%= change[:was].is_a?(Numeric) ? number_with_delimiter(change[:was]) : change[:was] %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-right font-medium">
                <% if field == :loan_ratio %>
                  <%= "#{(change[:now].to_f * 100).round}%" %>
                <% else %>
                  <%= change[:now].is_a?(Numeric) ? number_with_delimiter(change[:now]) : change[:now] %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-right font-medium">
                <% if change[:delta] %>
                  <span class="<%= change[:delta] > 0 ? 'text-green-600' : 'text-red-600' %>">
                    <%= change[:delta] > 0 ? "+" : "" %><%= number_with_delimiter(change[:delta]) %>
                  </span>
                <% else %>
                  -
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
