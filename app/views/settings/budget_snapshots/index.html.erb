<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">스냅샷 이력</h1>
    <%= link_to "예산 설정으로", settings_budget_path,
      class: "text-blue-600 text-sm underline" %>
  </div>

  <% if notice %>
    <div class="mb-4 p-3 bg-green-50 text-green-700 rounded-lg text-sm">
      <%= notice %>
    </div>
  <% end %>

  <% if @snapshots.any? %>
    <div class="space-y-3">
      <% @snapshots.each do |snapshot| %>
        <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50">
          <div class="flex justify-between items-start">
            <div>
              <span class="text-sm font-medium text-gray-500">v<%= snapshot.version %></span>
              <% trigger_class = case snapshot.trigger
                when 'onboarding' then 'bg-blue-100 text-blue-700'
                when 'manual_edit' then 'bg-green-100 text-green-700'
                when 'recalculate' then 'bg-amber-100 text-amber-700'
                else 'bg-gray-100 text-gray-700'
                end %>
              <span class="inline-block ml-2 px-2 py-0.5 text-xs rounded-full <%= trigger_class %>">
                <%= snapshot.trigger %>
              </span>
              <% if snapshot.max_bid_amount %>
                <p class="text-lg font-bold mt-1">최대입찰가: <%= number_with_delimiter(snapshot.max_bid_amount) %>만원</p>
              <% end %>
              <p class="text-xs text-gray-400 mt-1"><%= snapshot.calculated_at&.strftime("%Y-%m-%d %H:%M") %></p>
            </div>
            <div class="flex gap-2">
              <%= link_to "보기", settings_budget_snapshot_path(snapshot),
                class: "text-sm text-blue-600 underline" %>
              <%= button_to "재계산", recalculate_settings_budget_snapshot_path(snapshot),
                method: :post,
                class: "text-sm text-amber-600 underline" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @snapshots.size >= 2 %>
      <div class="mt-6 p-4 bg-gray-50 rounded-lg">
        <p class="text-sm font-medium text-gray-700 mb-2">스냅샷 비교</p>
        <%= form_tag compare_settings_budget_snapshots_path, method: :get, class: "flex gap-2 items-end" do %>
          <div class="flex-1">
            <label class="block text-xs text-gray-500 mb-1">기준</label>
            <select name="ids[]" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
              <% @snapshots.each do |s| %>
                <option value="<%= s.id %>">v<%= s.version %> (<%= s.trigger %>)</option>
              <% end %>
            </select>
          </div>
          <div class="flex-1">
            <label class="block text-xs text-gray-500 mb-1">비교 대상</label>
            <select name="ids[]" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
              <% @snapshots.each_with_index do |s, i| %>
                <option value="<%= s.id %>" <%= "selected" if i == 1 %>>v<%= s.version %> (<%= s.trigger %>)</option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="px-4 py-2 bg-gray-700 text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors">
            비교
          </button>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-500 text-center py-8">저장된 스냅샷이 없습니다.</p>
  <% end %>
</div>
