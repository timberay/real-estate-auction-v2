<% content_for(:page_title, "데이터 소스 설정") %>

<div class="mx-auto max-w-2xl">
  <p class="text-slate-600 dark:text-slate-400 mb-8">각 데이터 소스의 API 키를 설정하면 실제 데이터를 조회할 수 있습니다.</p>

  <div class="space-y-4">
    <% @providers.each do |key, config| %>
      <% credential = @credentials[key.to_s] %>
      <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-4">
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-slate-900 dark:text-slate-100"><%= config[:name_ko] %></h3>
        </div>
        <p class="text-sm text-slate-600 dark:text-slate-400 mb-4"><%= config[:description_ko] %></p>

        <% if config[:requires_consent] %>
          <%= form_with(
            scope: :api_credential,
            url: credential ? settings_api_credential_path(credential) : settings_api_credentials_path,
            method: credential ? :patch : :post,
            class: "flex items-center gap-3"
          ) do |f| %>
            <%= f.hidden_field :provider_name, value: key unless credential %>
            <label class="relative inline-flex items-center cursor-pointer">
              <%= f.check_box :enabled,
                checked: credential&.enabled?,
                class: "sr-only peer",
                onchange: "this.form.requestSubmit()" %>
              <div class="w-11 h-6 bg-slate-200 dark:bg-slate-600 rounded-full peer peer-checked:bg-blue-600 dark:peer-checked:bg-blue-500 after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
            </label>
            <span class="text-sm text-slate-600 dark:text-slate-400">데이터 수집 동의</span>
          <% end %>
          <p class="mt-2 text-sm text-yellow-700 dark:text-yellow-300 bg-yellow-100 dark:bg-yellow-900/20 rounded p-2">
            ⚠ 자동 수집은 이용약관에 따라 제한될 수 있습니다. 사용자 책임 하에 활성화해주세요.
          </p>
        <% elsif config[:requires_key] %>
          <%= form_with(
            scope: :api_credential,
            url: credential ? settings_api_credential_path(credential) : settings_api_credentials_path,
            method: credential ? :patch : :post,
            class: "space-y-3"
          ) do |f| %>
            <%= f.hidden_field :provider_name, value: key unless credential %>
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">API 키</label>
              <%= f.password_field :api_key,
                placeholder: credential ? "새 키를 입력하세요" : "API 키를 입력하세요",
                autocomplete: "off",
                spellcheck: false,
                class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 shadow-sm text-sm text-slate-900 dark:text-slate-100 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500/20 dark:focus:ring-blue-400/20 focus:border-blue-500 dark:focus:border-blue-400 transition-colors" %>
            </div>
            <div class="flex items-center gap-2">
              <%= f.submit(credential ? "업데이트" : "저장",
                class: "px-3 py-1.5 bg-blue-600 dark:bg-blue-500 text-white text-sm rounded-md hover:bg-blue-700 dark:hover:bg-blue-400 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900 cursor-pointer") %>
              <% if credential %>
                <%= button_to "검증", verify_settings_api_credential_path(credential),
                  method: :post,
                  class: "px-3 py-1.5 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 text-sm rounded-md hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900" %>
                <%= button_to "삭제", settings_api_credential_path(credential),
                  method: :delete,
                  data: { turbo_confirm: "정말 삭제하시겠습니까?" },
                  class: "px-3 py-1.5 text-red-600 dark:text-red-400 text-sm hover:underline transition-colors focus-visible:ring-2 focus-visible:ring-red-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900" %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
