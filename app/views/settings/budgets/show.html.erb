<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-6">예산 설정</h1>

  <% if notice %>
    <div class="mb-4 p-3 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 rounded-lg text-sm">
      <%= notice %>
    </div>
  <% end %>

  <% if @setting.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 rounded-lg text-sm">
      <% @setting.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @setting, url: settings_budget_path, method: :patch,
      data: { controller: "budget-calculator" } do |f| %>
    <%# Section 1: Available Cash %>
    <%= render CardComponent.new(title: "유용자금", class: "mb-6") do %>
      <div class="flex items-center gap-2" data-controller="number-format" data-number-format-initial-value="<%= @setting.available_cash %>">
        <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300">유용자금</label>
        <input type="text"
          class="flex-1 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"
          placeholder="예: 1억 3천"
          data-number-format-target="display"
          data-action="input->number-format#format input->budget-calculator#calculate blur->number-format#formatDisplay">
        <%= f.hidden_field :available_cash, data: { number_format_target: "hidden" } %>
        <span class="text-slate-600 dark:text-slate-400 font-medium">만원</span>
      </div>
    <% end %>

    <%# Section 2: Reserve Funds %>
    <%= render CardComponent.new(title: "예비비", class: "mb-6") do %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">부동산 유형</label>
        <%= f.collection_select :property_type_id, @property_types, :id, :name,
          { prompt: "선택하세요" },
          { class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" } %>
      </div>

      <div data-controller="area-unit" data-area-unit-unit-value="<%= @setting.area_unit %>">
        <div class="mb-4 grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                   data-area-unit-target="minLabel">면적 최소 (㎡)</label>
            <%= f.number_field :area_range_min, inputmode: "numeric",
              data: { area_unit_target: "minInput" },
              class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
                   data-area-unit-target="maxLabel">면적 최대 (㎡)</label>
            <%= f.number_field :area_range_max, inputmode: "numeric",
              data: { area_unit_target: "maxInput" },
              class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
          </div>
        </div>

        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">면적 단위</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-1 text-slate-700 dark:text-slate-300">
              <%= f.radio_button :area_unit, "pyeong", checked: @setting.area_unit == "pyeong",
                  data: { action: "change->area-unit#toggle" } %>
              <span>평</span>
            </label>
            <label class="flex items-center gap-1 text-slate-700 dark:text-slate-300">
              <%= f.radio_button :area_unit, "sqm", checked: @setting.area_unit == "sqm",
                  data: { action: "change->area-unit#toggle" } %>
              <span>㎡</span>
            </label>
          </div>
        </div>
      </div>

      <div class="space-y-3">
        <% [ [:repair_cost, "수선비"], [:acquisition_tax, "취득세"], [:scrivener_fee, "법무사비"],
             [:moving_cost, "이사비"], [:maintenance_fee, "관리비"] ].each do |field, label| %>
          <div class="flex items-center gap-2">
            <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300"><%= label %></label>
            <%= f.number_field field, inputmode: "numeric",
              data: { action: "input->budget-calculator#calculate" },
              class: "flex-1 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
            <span class="text-slate-600 dark:text-slate-400 text-sm">만원</span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Section 3: Loan Policy %>
    <%= render CardComponent.new(title: "대출 정책", class: "mb-6") do %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">대출 정책</label>
        <div class="space-y-2">
          <% @loan_policies.each do |policy| %>
            <label class="flex items-center gap-3 p-3 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700/50 cursor-pointer transition-colors">
              <%= f.radio_button :loan_policy_id, policy.id, class: "text-blue-600" %>
              <div>
                <span class="font-medium text-slate-900 dark:text-slate-100"><%= policy.policy_name %></span>
                <span class="text-sm text-slate-500 dark:text-slate-400 ml-2">LTV <%= (policy.loan_ratio * 100).to_i %>%</span>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div class="mb-4 grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">대출 비율 (LTV)</label>
          <%= f.number_field :loan_ratio, step: 0.01, min: 0, max: 1,
            data: { action: "input->budget-calculator#calculate" },
            class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">유찰 회차</label>
          <%= f.number_field :failed_auction_rounds, min: 0, max: 3,
            class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
        </div>
      </div>
    <% end %>

    <%# Current Results — always visible, updates in real-time %>
    <div class="mb-6 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4">
      <p class="text-sm text-slate-500 dark:text-slate-400">현재 최대입찰가</p>
      <p class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums" data-budget-calculator-target="display"><%= @setting.max_bid_amount ? format_price_in_eok(@setting.max_bid_amount) : "—" %></p>
    </div>

    <div class="flex gap-4">
      <%= render ButtonComponent.new(variant: :outline, tag: :a, href: settings_budget_snapshots_path, icon: "clock", class: "flex-1 justify-center") { "스냅샷 이력" } %>
      <%= render ButtonComponent.new(icon: "check", class: "flex-1 justify-center", type: "submit") { "저장" } %>
    </div>
  <% end %>
</div>
