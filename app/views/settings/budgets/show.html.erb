<% content_for(:page_title, "예산 설정") %>

<% if notice %>
  <div class="mb-4 p-3 bg-green-100 dark:bg-green-900/20 text-green-700 dark:text-green-400 rounded-lg text-sm">
    <%= notice %>
  </div>
<% end %>

<% if @setting.errors.any? %>
  <div class="mb-4 p-3 bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-400 rounded-lg text-sm">
    <% @setting.errors.full_messages.each do |msg| %>
      <p><%= msg %></p>
    <% end %>
  </div>
<% end %>

<%
  loan_policies_payload = @loan_policies_by_type.transform_values do |policies|
    policies.map do |p|
      { id: p.id, policy_name: p.policy_name,
        loan_ratio: p.loan_ratio.to_f,
        regulated_loan_ratio: p.regulated_loan_ratio.to_f }
    end
  end
%>
<%= form_with model: @setting, url: settings_budget_path, method: :patch,
    data: { controller: "budget-calculator",
            budget_calculator_loan_policies_by_type_value: loan_policies_payload.to_json,
            budget_calculator_regulated_regions_value: LoanPolicy::REGULATED_REGIONS.to_json } do |f| %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Left column — small settings %>
    <div class="space-y-6">
      <%# Section 0: Region %>
      <%= render CardComponent.new(title: "관심 지역") do %>
        <div class="flex items-center gap-2">
          <%= f.select :region,
            options_for_select(BudgetSetting::REGIONS, @setting.effective_region),
            {},
            class: "flex-1 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
            data: { controller: "region-select", region_select_url_value: update_region_settings_budget_path, region_select_target: "select", action: "change->region-select#save change->budget-calculator#regionChanged" } %>
        </div>
      <% end %>

      <%# Section 1: Available Cash %>
      <%= render CardComponent.new(title: "쓸 수 있는 현금") do %>
        <div class="flex items-center gap-2" data-controller="number-format" data-number-format-initial-value="<%= @setting.available_cash %>">
          <input type="text"
            class="flex-1 min-w-0 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"
            placeholder="예: 1억 3천"
            data-number-format-target="display"
            data-action="input->number-format#format input->budget-calculator#calculate blur->number-format#formatDisplay">
          <%= f.hidden_field :available_cash, data: { number_format_target: "hidden" } %>
          <span class="text-slate-600 dark:text-slate-400 font-medium text-sm whitespace-nowrap">만원</span>
        </div>
      <% end %>

      <%# Section 3: Loan Policy %>
      <%= render CardComponent.new(title: "대출 정책") do %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">대출 정책</label>
          <div class="space-y-2" data-budget-calculator-target="loanPolicyList">
            <% @loan_policies.each do |policy|
              effective_ratio = policy.ratio_for(@setting.effective_region) %>
              <label class="flex items-center gap-3 p-3 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700/50 cursor-pointer transition-colors">
                <%= f.radio_button :loan_policy_id, policy.id, class: "text-blue-600",
                    data: { action: "change->budget-calculator#applyPolicy", loan_ratio: effective_ratio } %>
                <div>
                  <span class="font-medium text-slate-900 dark:text-slate-100"><%= policy.policy_name %></span>
                  <span class="text-sm text-slate-500 dark:text-slate-400 ml-2">LTV <%= (effective_ratio * 100).to_i %>%</span>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">대출 비율 (LTV)</label>
            <span class="text-sm font-semibold text-slate-900 dark:text-slate-100 tabular-nums" data-budget-calculator-target="loanRatioDisplay"><%= (@setting.loan_ratio.to_f * 100).to_i %>%</span>
          </div>
          <input type="range" min="30" max="100" step="1"
                 value="<%= (@setting.loan_ratio.to_f * 100).to_i %>"
                 data-budget-calculator-target="loanRatioSlider"
                 data-action="input->budget-calculator#slideLoanRatio"
                 class="w-full accent-blue-600">
          <div class="flex justify-between text-sm text-slate-400 dark:text-slate-500 mt-1">
            <span>30%</span>
            <span>100%</span>
          </div>
          <%= f.hidden_field :loan_ratio, data: { budget_calculator_target: "loanRatioHidden" } %>
        </div>
      <% end %>
    </div>

    <%# Right column — Reserve Funds + result + submit %>
    <div class="lg:col-span-2 space-y-6">
      <%= render CardComponent.new(title: "예비비") do %>
        <div data-controller="reserve-fund"
             data-reserve-fund-defaults-value="<%= @reserve_defaults.to_json %>"
             data-reserve-fund-available-cash-value="<%= @setting.available_cash.to_i %>"
             data-reserve-fund-tax-brackets-value="<%= @tax_brackets.to_json %>"
             data-reserve-fund-loan-ratio-value="<%= @setting.loan_ratio.to_f.zero? ? 0.7 : @setting.loan_ratio.to_f %>"
             data-reserve-fund-acquisition-tax-auto-value="<%= @setting.acquisition_tax_auto %>"
             data-reserve-fund-precise-mode-value="<%= @setting.acquisition_tax_precise_mode %>"
             data-reserve-fund-area-over-85-value="<%= @setting.area_over_85? %>"
             data-action="reserve-fund:changed->budget-calculator#calculate">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">부동산 유형</label>
              <%= f.collection_select :property_type_id, @property_types, :id, :name,
                { prompt: "선택하세요" },
                { class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                  data: { reserve_fund_target: "propertyType",
                          action: "change->reserve-fund#propertyTypeChanged change->budget-calculator#propertyTypeChanged" } } %>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">관심 면적</label>
              <%= select_tag "budget_setting[area_category]",
                options_for_select(BudgetSetting.area_category_options, @setting.selected_area_category),
                prompt: "선택하세요",
                class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                data: { reserve_fund_target: "areaCategory",
                        action: "change->reserve-fund#areaChanged" } %>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                <span class="relative inline-flex items-center gap-1 cursor-help"
                      data-controller="tooltip"
                      data-tooltip-content-value="주택 수가 많을수록 취득세율이 높아집니다 (조정대상지역 2주택 8.4%, 3주택+ 12.4%)"
                      data-action="mouseenter->tooltip#show mouseleave->tooltip#hide">
                  주택 보유
                  <svg class="inline w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </span>
              </label>
              <%= f.select :household_tier, @household_tier_options,
                {},
                { class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                  data: { reserve_fund_target: "householdTier",
                          action: "change->reserve-fund#householdTierChanged" } } %>
            </div>
          </div>

          <%= f.hidden_field :acquisition_tax_auto, value: @setting.acquisition_tax_auto, data: { reserve_fund_target: "acquisitionTaxAuto" } %>

          <div class="mb-4">
            <label class="flex items-center gap-2">
              <%= f.check_box :acquisition_tax_precise_mode,
                    class: "rounded border-slate-300 dark:border-slate-600 text-blue-600 focus:ring-blue-500" %>
              <span class="text-sm font-medium text-slate-700 dark:text-slate-300">취득세 정밀 모드 (6~9억 누진식)</span>
            </label>
            <p class="text-sm text-slate-400 dark:text-slate-500 mt-1 ml-6">
              체크 시 매물 분석 페이지의 6~9억 구간 취득세를 누진식 <code class="text-xs">(가액×2/3 − 3) / 100</code>으로 계산합니다. 미체크 시 단일 세율(85㎡↓ 2.2%, 85㎡↑ 2.4%) 사용.
            </p>
          </div>

          <div class="mb-4">
            <label class="flex items-center gap-2">
              <input type="checkbox"
                     checked
                     data-reserve-fund-target="autoCalc"
                     data-action="change->reserve-fund#toggleAutoCalc"
                     class="rounded border-slate-300 dark:border-slate-600 text-blue-600 focus:ring-blue-500">
              <span class="text-sm font-medium text-slate-700 dark:text-slate-300">면적/유형에 따라 자동 계산</span>
            </label>
            <p class="text-sm text-slate-400 dark:text-slate-500 mt-1 ml-6">체크 시 부동산 유형과 면적에 따라 예비비가 자동 반영됩니다</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3">
            <% [
              [:repair_cost, "수선비", "repairCost", "수선비"],
              [:acquisition_tax, "취득세", "acquisitionTax", "취득세"],
              [:scrivener_fee, "법무사비", "scrivenerFee", "법무사비"],
              [:moving_cost, "이사비", "movingCost", "이사비"],
              [:maintenance_fee, "미납 관리비", "maintenanceFee", "미납 관리비"]
            ].each do |field, label, target, hint_default| %>
              <div>
                <div class="flex items-center gap-2">
                  <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300 shrink-0"><%= label %></label>
                  <%= f.number_field field, inputmode: "numeric",
                    class: "flex-1 min-w-0 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                    data: { reserve_fund_target: target,
                            reserve_fund_readonly_when_auto: (field == :acquisition_tax).to_s,
                            action: "input->reserve-fund#updateTotal input->budget-calculator#calculate" } %>
                  <span class="text-slate-600 dark:text-slate-400 text-sm whitespace-nowrap">만원</span>
                </div>
                <p class="ml-24 pl-2 mt-1 text-sm text-slate-400 dark:text-slate-500"
                   data-reserve-fund-target="<%= target %>Hint"><%= hint_default %></p>
              </div>
            <% end %>
          </div>

          <div class="mt-4 p-3 rounded-lg border transition-colors bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700"
               data-reserve-fund-target="summaryBox">
            <div class="flex justify-between items-center">
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">
                예비비 합계: <span class="tabular-nums" data-reserve-fund-target="total">0</span>만원
              </p>
              <p class="text-sm text-slate-500 dark:text-slate-400">
                쓸 수 있는 현금: <span class="tabular-nums"><%= number_with_delimiter(@setting.available_cash.to_i) %></span>만원
              </p>
            </div>
            <p class="mt-1 text-sm text-red-600 dark:text-red-400 hidden" data-reserve-fund-target="warning">
              예비비가 쓸 수 있는 현금을 초과합니다. 예비비를 조정해 주세요.
            </p>
          </div>
        </div>
      <% end %>

      <%# T1.5 — DSR (Debt Service Ratio) 입력. 미입력 시 profit_calculator
           가 경고 배너를 자체 숨김. 단위는 만원. %>
      <div class="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">DSR 한도 (선택)</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">
          연봉과 기존 부채의 월 상환액을 입력하면 입찰가가 DSR 40% 한도를 초과할 때 매물 페이지에서 경고를 표시합니다.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3">
          <div>
            <div class="flex items-center gap-2">
              <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300 shrink-0">연소득</label>
              <%= f.number_field :annual_income, inputmode: "numeric", min: 0,
                class: "flex-1 min-w-0 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
              <span class="text-slate-600 dark:text-slate-400 text-sm whitespace-nowrap">만원/년</span>
            </div>
            <p class="ml-24 pl-2 mt-1 text-sm text-slate-400 dark:text-slate-500">근로소득 + 사업소득 합산</p>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300 shrink-0">기존 부채 월상환</label>
              <%= f.number_field :existing_debt_monthly, inputmode: "numeric", min: 0,
                class: "flex-1 min-w-0 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
              <span class="text-slate-600 dark:text-slate-400 text-sm whitespace-nowrap">만원/월</span>
            </div>
            <p class="ml-24 pl-2 mt-1 text-sm text-slate-400 dark:text-slate-500">기존 대출 월 원리금 합계</p>
          </div>
        </div>
      </div>

      <%# Current Results — placed under 예비비, updates in real-time %>
      <div class="bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4">
        <p class="text-sm text-slate-500 dark:text-slate-400">현재 최대입찰가</p>
        <p class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums" data-budget-calculator-target="display"><%= @setting.max_bid_amount ? format_price_in_eok(@setting.max_bid_amount) : "—" %></p>
      </div>

      <%# Submit — right-aligned under the result panel %>
      <div class="flex justify-end">
        <button type="submit"
                class="inline-flex items-center justify-center gap-2 h-10 px-4 text-sm font-medium rounded-md bg-blue-600 hover:bg-blue-700 text-white dark:bg-blue-500 dark:hover:bg-blue-400 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          예산 저장
        </button>
      </div>
    </div>
  </div>
<% end %>
