<% content_for(:page_title, "예산 설정") %>

<% if notice %>
  <div class="mb-4 p-3 bg-green-100 dark:bg-green-900/20 text-green-700 dark:text-green-400 rounded-lg text-sm">
    <%= notice %>
  </div>
<% end %>

<% if @setting.errors.any? %>
  <div class="mb-4 p-3 bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-400 rounded-lg text-sm">
    <% @setting.errors.full_messages.each do |msg| %>
      <p><%= msg %></p>
    <% end %>
  </div>
<% end %>

<%= form_with model: @setting, url: settings_budget_path, method: :patch,
    data: { controller: "budget-calculator" } do |f| %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Left column — small settings %>
    <div class="space-y-6">
      <%# Section 0: Region %>
      <%= render CardComponent.new(title: "관심 지역") do %>
        <div class="flex items-center gap-2">
          <%= f.select :region,
            options_for_select(BudgetSetting::REGIONS, @setting.effective_region),
            {},
            class: "flex-1 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
            data: { controller: "region-select", region_select_url_value: update_region_settings_budget_path, region_select_target: "select", action: "change->region-select#save" } %>
        </div>
      <% end %>

      <%# Section 1: Available Cash %>
      <%= render CardComponent.new(title: "유용자금") do %>
        <div class="flex items-center gap-2" data-controller="number-format" data-number-format-initial-value="<%= @setting.available_cash %>">
          <input type="text"
            class="flex-1 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"
            placeholder="예: 1억 3천"
            data-number-format-target="display"
            data-action="input->number-format#format input->budget-calculator#calculate blur->number-format#formatDisplay">
          <%= f.hidden_field :available_cash, data: { number_format_target: "hidden" } %>
          <span class="text-slate-600 dark:text-slate-400 font-medium text-sm whitespace-nowrap">만원</span>
        </div>
      <% end %>

      <%# Section 3: Loan Policy %>
      <%= render CardComponent.new(title: "대출 정책") do %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">대출 정책</label>
          <div class="space-y-2">
            <% @loan_policies.each do |policy| %>
              <label class="flex items-center gap-3 p-3 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700/50 cursor-pointer transition-colors">
                <%= f.radio_button :loan_policy_id, policy.id, class: "text-blue-600",
                    data: { action: "change->budget-calculator#applyPolicy", loan_ratio: policy.loan_ratio } %>
                <div>
                  <span class="font-medium text-slate-900 dark:text-slate-100"><%= policy.policy_name %></span>
                  <span class="text-sm text-slate-500 dark:text-slate-400 ml-2">LTV <%= (policy.loan_ratio * 100).to_i %>%</span>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">대출 비율 (LTV)</label>
          <%= f.number_field :loan_ratio, step: 0.01, min: 0, max: 1,
            data: { action: "input->budget-calculator#calculate" },
            class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500" %>
        </div>
      <% end %>
    </div>

    <%# Right column — Reserve Funds (largest section) %>
    <div class="lg:col-span-2">
      <%= render CardComponent.new(title: "예비비") do %>
        <div data-controller="reserve-fund"
             data-reserve-fund-defaults-value="<%= @reserve_defaults.to_json %>"
             data-reserve-fund-available-cash-value="<%= @setting.available_cash.to_i %>"
             data-action="reserve-fund:changed->budget-calculator#calculate">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">부동산 유형</label>
              <%= f.collection_select :property_type_id, @property_types, :id, :name,
                { prompt: "선택하세요" },
                { class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                  data: { reserve_fund_target: "propertyType",
                          action: "change->reserve-fund#propertyTypeChanged" } } %>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">관심 면적</label>
              <%= select_tag "budget_setting[area_category]",
                options_for_select(BudgetSetting.area_category_options, @setting.selected_area_category),
                prompt: "선택하세요",
                class: "w-full h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                data: { reserve_fund_target: "areaCategory",
                        action: "change->reserve-fund#areaChanged" } %>
            </div>
          </div>

          <div class="mb-4">
            <label class="flex items-center gap-2">
              <input type="checkbox"
                     checked
                     data-reserve-fund-target="autoCalc"
                     data-action="change->reserve-fund#toggleAutoCalc"
                     class="rounded border-slate-300 dark:border-slate-600 text-blue-600 focus:ring-blue-500">
              <span class="text-sm font-medium text-slate-700 dark:text-slate-300">면적/유형에 따라 자동 계산</span>
            </label>
            <p class="text-sm text-slate-400 dark:text-slate-500 mt-1 ml-6">체크 시 부동산 유형과 면적에 따라 예비비가 자동 반영됩니다</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3">
            <% [
              [:repair_cost, "수선비", "repairCost", "수선비"],
              [:acquisition_tax, "취득세", "acquisitionTax", "취득세"],
              [:scrivener_fee, "법무사비", "scrivenerFee", "법무사비"],
              [:moving_cost, "이사비", "movingCost", "이사비"],
              [:maintenance_fee, "미납 관리비", "maintenanceFee", "미납 관리비"]
            ].each do |field, label, target, hint_default| %>
              <div>
                <div class="flex items-center gap-2">
                  <label class="w-24 text-sm font-medium text-slate-700 dark:text-slate-300 shrink-0"><%= label %></label>
                  <%= f.number_field field, inputmode: "numeric",
                    class: "flex-1 h-10 rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500",
                    data: { reserve_fund_target: target,
                            action: "input->reserve-fund#updateTotal input->budget-calculator#calculate" } %>
                  <span class="text-slate-600 dark:text-slate-400 text-sm whitespace-nowrap">만원</span>
                </div>
                <p class="ml-24 pl-2 mt-1 text-sm text-slate-400 dark:text-slate-500"
                   data-reserve-fund-target="<%= target %>Hint"><%= hint_default %></p>
              </div>
            <% end %>
          </div>

          <div class="mt-4 p-3 rounded-lg border transition-colors bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700"
               data-reserve-fund-target="summaryBox">
            <div class="flex justify-between items-center">
              <p class="text-sm font-medium text-slate-700 dark:text-slate-300">
                예비비 합계: <span class="tabular-nums" data-reserve-fund-target="total">0</span>만원
              </p>
              <p class="text-sm text-slate-500 dark:text-slate-400">
                유용자금: <span class="tabular-nums"><%= number_with_delimiter(@setting.available_cash.to_i) %></span>만원
              </p>
            </div>
            <p class="mt-1 text-sm text-red-600 dark:text-red-400 hidden" data-reserve-fund-target="warning">
              예비비가 유용자금을 초과합니다. 예비비를 조정해 주세요.
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Result + Submit — full-width sticky-feel footer %>
  <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 items-stretch">
    <div class="bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg p-4 flex flex-col justify-center">
      <p class="text-sm text-slate-500 dark:text-slate-400">현재 최대입찰가</p>
      <p class="text-2xl font-bold text-slate-900 dark:text-slate-100 tabular-nums" data-budget-calculator-target="display"><%= @setting.max_bid_amount ? format_price_in_eok(@setting.max_bid_amount) : "—" %></p>
    </div>

    <button type="submit"
            class="inline-flex items-center justify-center gap-2 h-12 px-6 text-base font-medium rounded-md bg-blue-600 hover:bg-blue-700 text-white dark:bg-blue-500 dark:hover:bg-blue-400 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-blue-500/50 focus-visible:ring-offset-2 dark:focus-visible:ring-blue-400/50 dark:focus-visible:ring-offset-slate-900">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
      예산 저장
    </button>
  </div>
<% end %>
