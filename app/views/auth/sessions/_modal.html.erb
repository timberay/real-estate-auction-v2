<%= turbo_frame_tag "auth_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" data-controller="auth-modal">
    <div class="bg-white dark:bg-slate-800 rounded-lg shadow-xl max-w-sm w-full mx-4 p-6">
      <div class="flex items-start justify-between mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">로그인</h2>
        <button type="button" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200" data-action="auth-modal#close" aria-label="닫기">
          &times;
        </button>
      </div>
      <p class="text-sm text-slate-600 dark:text-slate-300 mb-6">내 결과를 안전하게 저장하세요.</p>

      <div class="flex flex-col gap-2">
        <% ordered_providers.each do |provider| %>
          <%= button_to provider_path(provider), method: :post,
              form: { data: { turbo: false } },
              class: "w-full py-2.5 px-4 rounded-md font-medium text-sm border border-slate-300 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-900 dark:text-white",
              data: { action: "auth-modal#disable" } do %>
            <%= provider_label(provider) %>
          <% end %>
        <% end %>
      </div>

      <p class="text-xs text-slate-500 dark:text-slate-400 mt-6">
        계속 진행 시 <%= link_to "이용약관", terms_path, target: "_blank", class: "underline" %> 및
        <%= link_to "개인정보 처리방침", privacy_path, target: "_blank", class: "underline" %>에 동의합니다.
      </p>
    </div>
  </div>
<% end %>
