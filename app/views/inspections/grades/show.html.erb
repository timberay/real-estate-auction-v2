<%= render layout: "inspections/layout", locals: { property: @property, user_property: @user_property, active_tab: "grade" } do %>
  <% has_risks = @risk_results.any? %>
  <% beginner_mode = current_user&.beginner_mode? %>

  <%# ===== Status banner (above section 1) ===== %>
  <%= render GradeSummaryComponent.new(rating: @rating, fully_evaluated: @fully_evaluated, tabs_evaluated: @tabs_evaluated, tabs_total: @tabs_total, compact: true) %>

  <%# ===== B24 / B-18: Beginner-mode order guide callout ===== %>
  <% if beginner_mode %>
    <div class="rounded-lg border-l-4 border-blue-500 bg-blue-50 dark:bg-blue-900/20 p-4 mt-4 text-sm" role="note">
      <p class="font-semibold text-blue-900 dark:text-blue-100">초심자라면 1·2·3 순서로 보세요</p>
      <p class="mt-1 text-blue-800 dark:text-blue-200">
        1️⃣ 종합 판정 → 2️⃣ 물건 기본 정보 → 3️⃣ 순수익 계산기 순서로 살펴본 뒤,
        4번 이하는 필요할 때 차례로 보면 됩니다.
      </p>
    </div>
  <% end %>

  <%# ===== T3.1: 비주거 매물 세금 매트릭스 경고 ===== %>
  <% unless @property.residential? %>
    <% category_label = { officetel: "오피스텔", commercial: "상가", land: "토지", unknown: "분류 불명" }[@property.usage_category] %>
    <div class="rounded-md border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-400 p-4 mb-4 mt-4" role="note" data-testid="non-residential-tax-warning">
      <h3 class="font-semibold text-amber-900 dark:text-amber-100">
        ⚠️ <%= category_label %> 매물 — 세금 매트릭스 별도 확인 필요
      </h3>
      <p class="text-sm mt-1 text-amber-800 dark:text-amber-200">
        이 페이지의 취득세 / 양도세 계산은 주거용 부동산 기준입니다.
        <% case @property.usage_category %>
        <% when :officetel %>
          오피스텔은 주거용으로 등록한 경우만 1세대 1주택 비과세 대상이며, 그 외에는 사업용 부동산으로 분류됩니다.
        <% when :commercial %>
          상가는 일반세율(4.6% 등) 및 사업소득 양도세가 적용됩니다.
        <% when :land %>
          토지는 비사업용 양도세 중과(70% 추가) 가능성이 있으니 세무 전문가 확인을 권장합니다.
        <% else %>
          매물 유형이 분명하지 않으니 세무 전문가에게 확인하세요.
        <% end %>
      </p>
    </div>
  <% end %>

  <%# ===== A7: Incomplete-input warning banner ===== %>
  <% if @rating == :incomplete && @unanswered_high_priority_count > 0 %>
    <div class="rounded-md border-l-4 border-red-500 bg-red-50 dark:bg-red-900/20 dark:border-red-400 p-4 mb-6 mt-4">
      <h3 class="font-semibold text-red-900 dark:text-red-100">
        ⚠️ 입력 부족 — 입찰 검토 보류
      </h3>
      <p class="text-sm mt-1 text-red-800 dark:text-red-200">
        필수 권리분석 항목(<%= @unanswered_high_priority_count %>건) 미입력 상태입니다.
        안전 판정을 받기 전에 모든 필수 항목을 답변해 주세요.
      </p>
    </div>
  <% end %>

  <%# ===== Table of contents ===== %>
  <nav aria-label="목차" class="mt-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/40 p-4">
    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">목차</p>
    <ol class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1 text-sm">
      <li><a href="#section-verdict" class="text-blue-600 dark:text-blue-400 hover:underline">1. 종합 판정</a></li>
      <li><a href="#section-property" class="text-blue-600 dark:text-blue-400 hover:underline">2. 물건 기본 정보</a></li>
      <li><a href="#section-profit" class="text-blue-600 dark:text-blue-400 hover:underline">3. 순수익 계산기</a></li>
      <li><a href="#section-tabs" class="text-blue-600 dark:text-blue-400 hover:underline">4. 탭별 평가 요약</a></li>
      <% if has_risks %>
        <li><a href="#section-risks" class="text-blue-600 dark:text-blue-400 hover:underline">5. 위험 항목 상세</a></li>
      <% end %>
      <li><a href="#section-rights" class="text-blue-600 dark:text-blue-400 hover:underline"><%= has_risks ? 6 : 5 %>. 권리 분석 리포트</a></li>
      <% if has_risks %>
        <li><a href="#section-consultation" class="text-blue-600 dark:text-blue-400 hover:underline">7. 전문가 상담 가이드</a></li>
      <% end %>
      <li><a href="#section-eviction" class="text-blue-600 dark:text-blue-400 hover:underline"><%= has_risks ? 8 : 6 %>. 명도 시나리오</a></li>
    </ol>
  </nav>

  <%# ===== Numbered report sections ===== %>
  <div class="mt-10 space-y-10">
    <%= render ReportSectionComponent.new(
      number: 1, title: "종합 판정", anchor: "verdict",
      beginner_mode: beginner_mode,
      beginner_summary: "이 물건이 안전한지 한 눈에 확인하는 핵심 카드입니다."
    ) do %>
      <%= render BidOpinionComponent.new(
        risk_count: @risk_results.size,
        opportunity_count: @report&.opportunity_type.present? ? 1 : 0
      ) %>
    <% end %>

    <%= render ReportSectionComponent.new(
      number: 2, title: "물건 기본 정보", anchor: "property",
      beginner_mode: beginner_mode,
      beginner_summary: "주소·가격·매각기일 등 매물의 기본 정보입니다."
    ) do %>
      <%= render PropertyInfoComponent.new(property: @property, show_title: false) %>
    <% end %>

    <%= render ReportSectionComponent.new(
      number: 3, title: "순수익 계산기", anchor: "profit",
      beginner_mode: beginner_mode,
      beginner_summary: "낙찰가를 입력하면 예상 순수익을 자동 계산합니다."
    ) do %>
      <%= render ProfitCalculatorComponent.new(
        property: @property,
        budget_setting: @budget_setting,
        report: @report,
        show_title: false
      ) %>
    <% end %>

    <%= render ReportSectionComponent.new(
      number: 4, title: "탭별 평가 요약", anchor: "tabs",
      beginner_mode: beginner_mode,
      beginner_summary: "각 카테고리(권리·세금·명도)별 안전 등급 요약입니다."
    ) do %>
      <%= render TabSummaryTableComponent.new(results_by_tab: @results_by_tab, property: @property) %>
    <% end %>

    <% if has_risks %>
      <%= render ReportSectionComponent.new(
        number: 5, title: "위험 항목 상세", anchor: "risks",
        beginner_mode: beginner_mode,
        beginner_summary: "발견된 위험 항목들의 자세한 설명과 권장 대응입니다."
      ) do %>
        <%= render RiskItemsListComponent.new(risk_results: @risk_results) %>
      <% end %>
    <% end %>

    <%= render ReportSectionComponent.new(
      number: (has_risks ? 6 : 5), title: "권리 분석 리포트", anchor: "rights",
      beginner_mode: beginner_mode,
      beginner_summary: "등기부등본 기반 권리 시점·금액 분석입니다."
    ) do %>
      <%= render RightsReportSectionComponent.new(report: @report, property: @property, show_title: false) %>
    <% end %>

    <% if has_risks %>
      <%= render ReportSectionComponent.new(
        number: 7, title: "전문가 상담 가이드", anchor: "consultation",
        beginner_mode: beginner_mode,
        beginner_summary: "이 항목은 전문가와 상의해 결정하는 게 안전합니다."
      ) do %>
        <%= render ConsultationGuideComponent.new(risk_results: @risk_results, show_title: false) %>
      <% end %>
    <% end %>

    <%= render ReportSectionComponent.new(
      number: (has_risks ? 8 : 6), title: "명도 시나리오", anchor: "eviction",
      beginner_mode: beginner_mode,
      beginner_summary: "낙찰 후 점유자에게 인도받기까지 예상 절차와 비용입니다."
    ) do %>
      <div class="rounded-lg border border-slate-200 dark:border-slate-700 p-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-sm text-slate-600 dark:text-slate-400">이 물건의 명도 난이도와 절차를 미리 확인할 수 있습니다.</p>
          </div>
          <a href="<%= eviction_guide_simulator_path(property_id: @property.id) %>"
             class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 whitespace-nowrap">
            명도 시나리오 보기 →
          </a>
        </div>
      </div>
    <% end %>
  </div>

  <%# ===== Footer actions ===== %>
  <div class="mt-10 flex flex-wrap gap-3">
    <%= link_to property_inspections_grade_path(@property, format: :pdf),
        class: "flex-1 min-w-[10rem] rounded-lg bg-blue-600 dark:bg-blue-500 px-4 py-3 text-sm font-semibold text-center text-white hover:bg-blue-700 dark:hover:bg-blue-600 transition-colors",
        data: { turbo: false } do %>
      PDF 다운로드
    <% end %>
    <%# C14: equal-weight CTA next to PDF so users have a path to deeper
         help rather than walking away with a PDF and no answer to
         "should I bid?". Lands on the manual where expert-consultation
         guidance lives. %>
    <%= link_to manual_path,
        class: "flex-1 min-w-[10rem] rounded-lg border border-slate-300 dark:border-slate-600 px-4 py-3 text-sm font-semibold text-center text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors" do %>
      전문가 상담 가이드
    <% end %>
    <%= link_to property_inspections_grade_path(@property, format: :csv),
        class: "flex-1 min-w-[10rem] rounded-lg border border-slate-300 dark:border-slate-600 px-4 py-3 text-sm font-semibold text-center text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors",
        data: { turbo: false } do %>
      CSV 다운로드
    <% end %>
    <%= link_to "목록으로 돌아가기", properties_path, class: "flex-1 min-w-[10rem] rounded-lg border border-slate-300 dark:border-slate-600 px-4 py-3 text-sm font-semibold text-center text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors" %>
  </div>
<% end %>
