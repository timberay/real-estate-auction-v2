<%# app/views/properties/compare.html.erb %>
<% content_for(:page_title, "물건 비교 · #{@user_properties.size}건") %>

<div class="space-y-4">
  <div class="flex items-center justify-between flex-wrap gap-2">
    <%= link_to "← 목록으로", properties_path,
        class: "text-sm text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300" %>
    <h1 class="text-lg font-semibold text-slate-900 dark:text-slate-100">물건 비교 · <%= @user_properties.size %>건</h1>
  </div>

  <div class="overflow-x-auto rounded-lg border border-slate-200 dark:border-slate-700">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
          <th class="px-4 py-3 text-left font-semibold text-slate-600 dark:text-slate-300 whitespace-nowrap w-32">항목</th>
          <% @user_properties.each do |up| %>
            <th class="px-4 py-3 text-left font-semibold text-slate-600 dark:text-slate-300 whitespace-nowrap">
              <%= link_to up.property.case_number, property_path(up.property),
                  class: "hover:text-blue-600 dark:hover:text-blue-400" %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
        <tr class="bg-white dark:bg-slate-900">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">법원</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 text-slate-700 dark:text-slate-300"><%= up.property.court_name.presence || "—" %></td>
          <% end %>
        </tr>
        <tr class="bg-slate-50 dark:bg-slate-800/50">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">주소</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 text-slate-700 dark:text-slate-300"><%= up.property.address.presence || "—" %></td>
          <% end %>
        </tr>
        <tr class="bg-white dark:bg-slate-900">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">감정가</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 font-medium text-slate-700 dark:text-slate-300"><%= format_price_won(up.property.appraisal_price) %></td>
          <% end %>
        </tr>
        <tr class="bg-slate-50 dark:bg-slate-800/50">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">최저가</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 font-medium text-slate-700 dark:text-slate-300"><%= format_price_won(up.property.min_bid_price) %></td>
          <% end %>
        </tr>
        <tr class="bg-white dark:bg-slate-900">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">유찰횟수</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 text-slate-700 dark:text-slate-300"><%= up.property.failed_bid_count %>회</td>
          <% end %>
        </tr>
        <tr class="bg-slate-50 dark:bg-slate-800/50">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">다음 매각기일</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 text-slate-700 dark:text-slate-300">
              <% schedule = up.property.next_auction_schedule %>
              <%= schedule&.schedule_date&.strftime("%Y.%m.%d") || "—" %>
            </td>
          <% end %>
        </tr>
        <tr class="bg-white dark:bg-slate-900">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">종합판정</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3">
              <% rating = @ratings_by_property[up.property_id] %>
              <%= render SafetyBadgeComponent.new(rating: rating) %>
            </td>
          <% end %>
        </tr>
        <tr class="bg-slate-50 dark:bg-slate-800/50">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">인수금액</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 text-slate-700 dark:text-slate-300">
              <% report = @reports_by_property[up.property_id] %>
              <%= report ? format_price_won(report.total_risk_amount) : "—" %>
            </td>
          <% end %>
        </tr>
        <tr class="bg-white dark:bg-slate-900">
          <td class="px-4 py-3 text-slate-500 dark:text-slate-400 font-medium whitespace-nowrap">임차인수</td>
          <% @user_properties.each do |up| %>
            <td class="px-4 py-3 text-slate-700 dark:text-slate-300">
              <% report = @reports_by_property[up.property_id] %>
              <%= report ? "#{report.effective_tenants.size}명" : "—" %>
            </td>
          <% end %>
        </tr>
      </tbody>
    </table>
  </div>

  <p class="text-xs text-slate-400 dark:text-slate-500">
    종합판정은 체크리스트 완료 여부에 따라 '미완료'로 표시될 수 있습니다.
  </p>
</div>
