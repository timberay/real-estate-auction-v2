<% has_power = tenant["opposing_power"] %>
<% user_edited = tenant["user_edited"] %>
<div class="rounded-lg border p-3 <%= has_power ? 'border-red-400 bg-red-50 dark:border-red-600 dark:bg-red-900/20' : 'border-green-400 bg-green-50 dark:border-green-600 dark:bg-green-900/20' %>">
  <div class="flex items-center justify-between">
    <div class="text-sm">
      <span class="font-semibold text-slate-900 dark:text-slate-100"><%= tenant["name"] %> — 전입신고</span>
      <span class="ml-2 text-sm px-1.5 py-0.5 rounded <%= has_power ? 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300' : 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300' %>">
        대항력 <%= has_power ? '있음' : '없음' %>
      </span>
      <% if user_edited %>
        <span class="ml-2 inline-flex items-center rounded bg-yellow-100 dark:bg-yellow-900/30 px-1.5 py-0.5 text-xs text-yellow-800 dark:text-yellow-200">
          사용자 수정
        </span>
      <% end %>
      <% if tenant["same_day_warning"] %>
        <span class="ml-2 inline-flex items-center rounded bg-orange-100 dark:bg-orange-900/30 px-2 py-0.5 text-xs text-orange-900 dark:text-orange-200" title="<%= tenant['warning_message'] %>">
          동일자 전입 — 추가 확인 필요
        </span>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-sm text-slate-500 dark:text-slate-400"><%= tenant["move_in_date"] %></span>
      <% if property %>
        <%= link_to "수정",
              edit_property_report_tenant_path(property, index),
              class: "text-xs text-blue-600 dark:text-blue-400 hover:underline",
              data: { turbo_frame: "tenant-row-#{index}" } %>
      <% end %>
    </div>
  </div>
  <div class="text-sm text-slate-500 dark:text-slate-400 mt-1">
    보증금: <%= number_with_delimiter(tenant["deposit"]) %>원 · 확정일자: <%= tenant["confirmed_date"] || "없음" %> ·
    <% if tenant["dividend_requested"].nil? %>
      <span class="text-zinc-400">확인 필요</span>
    <% elsif tenant["dividend_requested"] %>
      <span class="text-emerald-700">배당요구 ○</span>
    <% else %>
      <span class="text-zinc-700">배당요구 ✗</span>
    <% end %>
  </div>
</div>
