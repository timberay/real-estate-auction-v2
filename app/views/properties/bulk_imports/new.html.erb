<% content_for(:page_title, "여러 건 한 번에 추가") %>

<%# app/views/properties/bulk_imports/new.html.erb %>
<div class="space-y-6 max-w-2xl">
  <div>
    <h1 class="text-xl font-semibold text-slate-900 dark:text-slate-100">여러 건 한 번에 추가</h1>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
      최대 50건. 형식: '법원이름,사건번호' (콤마/탭/공백 구분 모두 OK).
    </p>
  </div>

  <%= form_with url: bulk_import_properties_path, method: :post, multipart: true do |f| %>
    <div class="space-y-4">
      <%= f.text_area :bulk_input, rows: 12,
          placeholder: "예시:\n서울중앙지방법원,2026타경1234\n수원지방법원,2025타경5678",
          class: "w-full rounded-md border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 font-mono" %>

      <div class="flex items-center gap-3">
        <div class="flex-1 border-t border-slate-200 dark:border-slate-600"></div>
        <span class="text-xs text-slate-400 dark:text-slate-500">또는 CSV 파일 업로드</span>
        <div class="flex-1 border-t border-slate-200 dark:border-slate-600"></div>
      </div>

      <%= f.file_field :csv_file, accept: ".csv,.txt",
          class: "block text-sm text-slate-500 dark:text-slate-400 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-slate-100 file:text-slate-700 dark:file:bg-slate-700 dark:file:text-slate-300 hover:file:bg-slate-200 dark:hover:file:bg-slate-600" %>

      <button type="submit"
              class="inline-flex items-center justify-center h-10 px-5 text-sm font-medium rounded-md bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400 text-white transition-colors">
        한 번에 추가하기
      </button>
    </div>
  <% end %>

  <% if @result.present? %>
    <%# Truncation banner %>
    <% if @result.truncated_count > 0 %>
      <div class="rounded-md bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 px-4 py-3 text-sm text-yellow-800 dark:text-yellow-300">
        최대 50건까지 한 번에 처리합니다. 처음 50건만 처리되었어요. (입력: <%= @result.total + @result.truncated_count %>건)
      </div>
    <% end %>

    <%# Summary banner %>
    <% all_ok = @result.failed.empty? && @result.succeeded.any? %>
    <% all_bad = @result.succeeded.empty? && @result.failed.any? %>
    <% banner_classes = if all_ok
         "bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-700 text-green-800 dark:text-green-300"
       elsif all_bad
         "bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-700 text-red-800 dark:text-red-300"
       else
         "bg-yellow-50 dark:bg-yellow-900/20 border-yellow-200 dark:border-yellow-700 text-yellow-800 dark:text-yellow-300"
       end %>
    <div class="rounded-md border px-4 py-3 text-sm font-medium <%= banner_classes %>">
      총 <%= @result.total %>건 처리 — 성공 <%= @result.succeeded.size %>건, 실패 <%= @result.failed.size %>건
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <%# Success section %>
      <% if @result.succeeded.any? %>
        <div class="space-y-2">
          <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300">성공 (<%= @result.succeeded.size %>건)</h2>
          <ul class="space-y-1">
            <% @result.succeeded.each do |row| %>
              <li class="text-sm text-slate-600 dark:text-slate-400">
                <%= link_to row.property.case_number, property_path(row.property),
                    class: "underline hover:text-blue-600 dark:hover:text-blue-400" %>
                <% if row.already_existed %>
                  <span class="text-xs text-slate-400 dark:text-slate-500">(이미 추가됨)</span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Failure section %>
      <% if @result.failed.any? %>
        <div class="space-y-2">
          <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300">실패 (<%= @result.failed.size %>건)</h2>
          <ul class="space-y-2">
            <% @result.failed.each do |row| %>
              <li class="text-sm">
                <p class="text-slate-500 dark:text-slate-400 font-mono truncate" title="<%= row.raw %>"><%= row.raw %></p>
                <p class="text-red-600 dark:text-red-400"><%= row.error_message %></p>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
