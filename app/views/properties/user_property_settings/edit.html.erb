<turbo-frame id="user-property-notes-edit">
  <%= form_with model: @user_property,
        url: property_user_property_settings_path(@property),
        method: :patch do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" for="user_property_notes">메모</label>
        <%= f.text_area :notes,
              id: "user_property_notes",
              rows: 5,
              placeholder: "예) OO부동산 사장님 010-1234-5678 시세 8.5억",
              class: "w-full rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 placeholder:text-slate-400" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" for="user_property_inspection_visited_on">임장 일자</label>
        <%= f.date_field :inspection_visited_on,
              id: "user_property_inspection_visited_on",
              class: "rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" for="user_property_payment_completed_on">매각대금 납부일</label>
        <%= f.date_field :payment_completed_on,
              id: "user_property_payment_completed_on",
              class: "rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100" %>
        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
          납부일로부터 6개월 이내에 인도명령을 신청해야 합니다. 마감 30일 전·7일 전·당일에 알림을 받습니다.
        </p>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1" for="user_property_deposit_rate">보증금 비율 (%)</label>
        <%= f.number_field :deposit_rate,
              id: "user_property_deposit_rate",
              step: "0.01", min: "0", max: "1",
              class: "rounded border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 w-32" %>
        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
          일반 부동산 경매는 최저가의 10% (0.10). 재매각·공유지분 등 특별 사건은 사건 정보에서 확인 후 비율(예: 0.20)을 입력하세요.
          <% if @user_property.shared_ownership? %>
            <span class="block mt-1 text-yellow-700 dark:text-yellow-400 font-medium">
              ⚠️ 공유지분 매물(<%= @property.property_count %>건)입니다. 보증금 비율을 사건 정보에서 확인하세요.
            </span>
          <% end %>
        </p>
      </div>
      <div class="flex gap-2">
        <%= f.submit "저장",
              class: "rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
        <%= link_to "취소",
              property_path(@property),
              class: "rounded border border-slate-300 dark:border-slate-600 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700",
              data: { turbo_frame: "user-property-notes-edit" } %>
      </div>
    </div>
  <% end %>
</turbo-frame>
