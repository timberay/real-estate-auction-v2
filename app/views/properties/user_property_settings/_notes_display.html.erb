<turbo-frame id="user-property-notes-edit">
  <% has_content = user_property.notes.present? || user_property.inspection_visited_on.present? || user_property.payment_completed_on.present? || user_property.estimated_deposit.present? %>
  <% if has_content %>
    <div class="space-y-2">
      <% if user_property.notes.present? %>
        <p class="text-sm text-slate-800 dark:text-slate-200 whitespace-pre-wrap"><%= user_property.notes %></p>
      <% end %>
      <% if user_property.inspection_visited_on.present? %>
        <p class="text-sm text-slate-500 dark:text-slate-400">
          임장일: <span class="text-slate-700 dark:text-slate-300 font-medium"><%= user_property.inspection_visited_on.strftime("%Y.%m.%d") %></span>
        </p>
      <% end %>
      <% if user_property.estimated_deposit.present? %>
        <p class="text-sm text-slate-500 dark:text-slate-400" data-testid="estimated-deposit-display">
          예상 보증금
          <% if user_property.shared_ownership? %>
            <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300" data-testid="shared-ownership-badge">공유지분 <%= property.property_count %>건</span>
          <% end %>:
          <span class="text-slate-700 dark:text-slate-300 font-medium"><%= format_price_won(user_property.estimated_deposit) %></span>
          <span class="ml-1 text-xs text-slate-400 dark:text-slate-500">(최저가 × <%= (user_property.deposit_rate * 100).to_i %>%)</span>
        </p>
      <% end %>

      <% if user_property.payment_completed_on.present? %>
        <% days = user_property.days_to_eviction_deadline %>
        <% deadline = user_property.eviction_deadline %>
        <p class="text-sm text-slate-500 dark:text-slate-400" data-testid="eviction-deadline-display">
          매각대금 납부일: <span class="text-slate-700 dark:text-slate-300 font-medium"><%= user_property.payment_completed_on.strftime("%Y.%m.%d") %></span>
          <span class="block mt-0.5">
            인도명령 마감 <span class="text-slate-700 dark:text-slate-300 font-medium"><%= deadline.strftime("%Y.%m.%d") %></span>
            <% if days >= 0 %>
              <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= days <= 7 ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300' : days <= 30 ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300' : 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300' %>">
                <%= days == 0 ? "D-day" : "D-#{days}" %>
              </span>
            <% else %>
              <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                D+<%= days.abs %> (마감 경과)
              </span>
            <% end %>
          </span>
        </p>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-400 dark:text-slate-500">메모 없음</p>
  <% end %>
  <div class="mt-3">
    <%= link_to "메모 편집",
          edit_property_user_property_settings_path(property),
          class: "text-sm text-blue-600 dark:text-blue-400 hover:underline",
          data: { turbo_frame: "user-property-notes-edit" } %>
  </div>
</turbo-frame>
